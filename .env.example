# Twitch API Configuration
# Get these from https://dev.twitch.tv/console/apps

TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=your_client_secret_here
TWITCH_USERNAME=vocino

# Instagram Graph API (Business/Creator account + Facebook Page)
# https://developers.facebook.com/docs/instagram-platform/instagram-graph-api
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
# Optional: caption must include this hashtag (default vocino)
# INSTAGRAM_HASHTAG=vocino
