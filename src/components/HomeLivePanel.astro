---
const twitchHref = 'https://twitch.tv/vocino';
---

<section class="micro-panel micro-panel--live" aria-labelledby="live-heading">
  <header class="micro-panel__header">
    <p class="micro-label">live status</p>
    <p class="micro-stamp" id="live-health">checking</p>
  </header>

  <h2 id="live-heading" class="micro-panel__title">Twitch Telemetry</h2>

  <dl class="spec-table spec-table--live" id="live-spec-table">
    <div class="spec-table__row">
      <dt>status</dt>
      <dd id="live-status">checking...</dd>
    </div>
    <div class="spec-table__row">
      <dt>stream</dt>
      <dd id="live-title">Loading stream data</dd>
    </div>
    <div class="spec-table__row">
      <dt>game</dt>
      <dd id="live-game">Pending</dd>
    </div>
    <div class="spec-table__row">
      <dt>checked</dt>
      <dd id="live-checked">now</dd>
    </div>
  </dl>

  <a class="micro-link micro-link--live" href={twitchHref} rel="me" target="_blank">
    Open stream channel
  </a>
</section>

<script>
  function formatClock(date = new Date()) {
    return date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
  }

  function setLiveState(state = { online: false, title: '', game: '', health: 'ok' }) {
    const status = document.getElementById('live-status');
    const streamTitle = document.getElementById('live-title');
    const streamGame = document.getElementById('live-game');
    const checked = document.getElementById('live-checked');
    const healthStamp = document.getElementById('live-health');
    const specTable = document.getElementById('live-spec-table');

    if (!status || !streamTitle || !streamGame || !checked || !healthStamp || !specTable) return;

    status.textContent = state.online ? 'online' : 'offline';
    streamTitle.textContent = state.title || (state.online ? 'Live now' : 'No active stream');
    streamGame.textContent = state.game || 'n/a';
    checked.textContent = formatClock(new Date());
    healthStamp.textContent = state.health;

    specTable.dataset.liveState = state.online ? 'online' : 'offline';
    specTable.dataset.healthState = state.health;
  }

  async function fetchLiveState() {
    try {
      const response = await fetch('/api/twitch-status');
      const data = await response.json();

      if (!response.ok || data.error) {
        throw new Error(data.error || 'Live status unavailable');
      }

      setLiveState({
        online: Boolean(data.online),
        title: data.title ?? '',
        game: data.game ?? '',
        health: 'ok',
      });
    } catch (error) {
      console.error('Live panel error:', error);
      setLiveState({
        online: false,
        title: 'Telemetry degraded',
        game: '',
        health: 'degraded',
      });
    }
  }

  fetchLiveState();
  setInterval(fetchLiveState, 60000);
</script>
