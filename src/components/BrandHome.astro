---
import BrandMark from './BrandMark.astro';

// The one constant across every hub: the Vocino mark, top-left, linking home.
// Color inherits from `--section-accent` (via `.site-brand`) so the logo
// re-tints to match the hub it's rendered inside.
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const cls = ["site-brand", "site-brand--mark", "brand-home", className]
  .filter(Boolean)
  .join(" ");
---

<a href="/" class={cls} aria-label="Vocino — home">
  <BrandMark />
</a>

<style>
  /* Expand the click/tap target without moving the logo: padding grows the
     hit area, the matching negative margin keeps it visually in the corner. */
  a.brand-home {
    margin: -0.6rem;
    padding: 0.6rem;
    border-radius: 10px;
    transition: background-color 0.25s ease;
  }

  a.brand-home:hover,
  a.brand-home:focus-visible {
    background-color: color-mix(in srgb, var(--section-accent, var(--brand)) 12%, transparent);
  }

  a.brand-home:focus-visible {
    outline: 2px solid var(--section-accent, var(--brand));
    outline-offset: 2px;
  }
</style>
