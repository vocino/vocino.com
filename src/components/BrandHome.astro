---
// The one constant across every hub: the Vocino mark, top-left, linking home.
// Color inherits from `--section-accent` so the logo re-tints to match the
// hub it's rendered inside (green on /bg3, amber on /homelab, cyan at root).
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const cls = ["site-brand", "site-brand--mark", "brand-home", className]
  .filter(Boolean)
  .join(" ");
---

<a href="/" class={cls} aria-label="Vocino — home">
  <svg
    class="brand-logo"
    width="80"
    height="69"
    viewBox="0 0 250 216"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
    focusable="false"
  >
    <path d="M125 215.909L0 0L250 2.17954e-05L125 215.909Z" fill="currentColor" />
    <path d="M125 71.9697L83.3334 0L166.667 7.26513e-06L125 71.9697Z" fill="var(--bg, #0F1419)" />
  </svg>
</a>
