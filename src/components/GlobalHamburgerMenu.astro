---
import { siteNav } from '../data/site-nav';

const externalRel = (...tokens: (string | undefined)[]) => tokens.filter(Boolean).join(' ');
---

<div class="global-menu" data-global-menu data-open="false">
  <button
    class="global-menu__toggle"
    type="button"
    aria-expanded="false"
    aria-controls="global-menu-panel"
    aria-label="Open navigation menu"
    data-global-menu-toggle
  >
    <span class="global-menu__bars" aria-hidden="true"></span>
  </button>

  <div class="global-menu__overlay" data-global-menu-overlay aria-hidden="true" inert>
    <button type="button" class="global-menu__backdrop" data-global-menu-close aria-label="Close menu"></button>

    <nav id="global-menu-panel" class="global-menu__panel" aria-label="Site navigation" data-global-menu-panel>
      <ul class="global-menu__list">
        <li>
          <a class="global-menu__link" href={siteNav.home.href}>{siteNav.home.label}</a>
        </li>
        {
          siteNav.gaming.map((link) => (
            <li>
              <a class="global-menu__link" href={link.href}>
                {link.label}
              </a>
            </li>
          ))
        }
        {
          siteNav.elsewhere.map((item) => (
            <li>
              <a
                class="global-menu__link"
                href={item.href}
                rel={externalRel(item.rel, 'noopener', 'noreferrer')}
                target="_blank"
              >
                {item.label}
                <span class="global-menu__sr-only">(opens in new tab)</span>
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</div>

<script>
  (() => {
    const root = document.querySelector('[data-global-menu]');
    if (!root) return;

    const toggle = root.querySelector('[data-global-menu-toggle]');
    const overlay = root.querySelector('[data-global-menu-overlay]');
    const closeBtn = root.querySelector('[data-global-menu-close]');
    const panel = root.querySelector('[data-global-menu-panel]');

    if (
      !(toggle instanceof HTMLButtonElement) ||
      !(overlay instanceof HTMLElement) ||
      !(closeBtn instanceof HTMLButtonElement) ||
      !(panel instanceof HTMLElement)
    ) {
      return;
    }

    const setOpen = (open: boolean) => {
      root.setAttribute('data-open', open ? 'true' : 'false');
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      toggle.setAttribute('aria-label', open ? 'Close navigation menu' : 'Open navigation menu');
      overlay.setAttribute('aria-hidden', open ? 'false' : 'true');
      if (open) {
        overlay.removeAttribute('inert');
      } else {
        overlay.setAttribute('inert', '');
      }

      document.body.style.overflow = open ? 'hidden' : '';
    };

    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      setOpen(!isOpen);
    });

    closeBtn.addEventListener('click', () => {
      setOpen(false);
      toggle.focus();
    });

    panel.addEventListener('click', (event) => {
      const target = event.target;
      if (target instanceof HTMLElement && target.closest('a')) {
        setOpen(false);
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') return;
      if (toggle.getAttribute('aria-expanded') !== 'true') return;
      setOpen(false);
      toggle.focus();
    });
  })();
</script>

<style>
  .global-menu {
    --gm-panel-bg: var(--bg, #0f1419);
    --gm-panel-edge: var(--border, #2b3440);
    --gm-row-hover: var(--selection, #263040);
    --gm-backdrop: rgba(5, 8, 12, 0.88);

    position: fixed;
    top: 10px;
    left: 10px;
    z-index: 90;
    font-family:
      'Source Sans 3',
      -apple-system,
      BlinkMacSystemFont,
      'Segoe UI',
      Roboto,
      'Helvetica Neue',
      sans-serif;
    font-size: 0.8125rem;
    line-height: 1.35;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    font-feature-settings: 'kern' 1, 'liga' 1, 'calt' 1;
  }

  .global-menu__toggle {
    position: relative;
    z-index: 92;
    width: 40px;
    height: 40px;
    border: none;
    border-radius: 50%;
    background: transparent;
    color: var(--text-muted, #6b7785);
    font: inherit;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: color 0.2s ease;
  }

  .global-menu__toggle:hover,
  .global-menu__toggle:focus-visible {
    color: var(--text-secondary, #9ba7b4);
    outline: none;
  }

  .global-menu__toggle:focus-visible {
    box-shadow: 0 0 0 2px var(--bg, #0f1419), 0 0 0 4px color-mix(in srgb, var(--brand, #00ccff) 50%, transparent);
  }

  .global-menu__bars,
  .global-menu__bars::before,
  .global-menu__bars::after {
    transform-origin: center;
    transition: transform 0.2s ease;
  }

  .global-menu__bars {
    position: relative;
    width: 14px;
    height: 2px;
    border-radius: 1px;
    background: currentColor;
  }

  .global-menu__bars::before,
  .global-menu__bars::after {
    content: '';
    position: absolute;
    left: 0;
    width: 14px;
    height: 2px;
    border-radius: 1px;
    background: currentColor;
  }

  .global-menu__bars::before {
    top: -5px;
  }

  .global-menu__bars::after {
    top: 5px;
  }

  .global-menu__toggle[aria-expanded='true'] .global-menu__bars {
    background: transparent;
  }

  .global-menu__toggle[aria-expanded='true'] .global-menu__bars::before {
    transform: translateY(5px) rotate(45deg);
  }

  .global-menu__toggle[aria-expanded='true'] .global-menu__bars::after {
    transform: translateY(-5px) rotate(-45deg);
  }

  .global-menu__overlay {
    position: fixed;
    inset: 0;
    z-index: 91;
    display: grid;
    grid-template-columns: minmax(min(268px, 82vw), 1fr);
    visibility: hidden;
    pointer-events: none;
    transition: visibility 0.2s linear;
  }

  .global-menu[data-open='true'] .global-menu__overlay {
    visibility: visible;
    pointer-events: auto;
  }

  .global-menu__backdrop {
    grid-column: 1 / -1;
    grid-row: 1;
    margin: 0;
    padding: 0;
    border: none;
    background: var(--gm-backdrop);
    opacity: 0;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .global-menu[data-open='true'] .global-menu__backdrop {
    opacity: 1;
  }

  .global-menu__panel {
    grid-column: 1;
    grid-row: 1;
    z-index: 1;
    width: min(268px, 82vw);
    max-width: 100%;
    justify-self: start;
    height: 100%;
    overflow: auto;
    box-sizing: border-box;
    margin: 0;
    padding: 4.5rem 1rem 1.25rem;
    background: var(--gm-panel-bg);
    color: var(--text-secondary, #9ba7b4);
    box-shadow:
      10px 0 40px rgba(0, 0, 0, 0.55),
      inset -1px 0 0 color-mix(in srgb, var(--gm-panel-edge) 85%, transparent);
    transform: translateX(-100%);
    transition: transform 0.22s ease;
    border-right: 1px solid var(--gm-panel-edge);
  }

  .global-menu[data-open='true'] .global-menu__panel {
    transform: translateX(0);
  }

  .global-menu__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .global-menu__list li + li {
    border-top: 1px solid color-mix(in srgb, var(--gm-panel-edge) 72%, transparent);
  }

  .global-menu__link {
    display: block;
    margin: 0 -0.25rem;
    padding: 0.5625rem 0.375rem;
    border-radius: 4px;
    text-decoration: none;
    font-size: 0.8125rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1.35;
    color: var(--text-secondary, #9ba7b4);
    transition:
      color 0.2s cubic-bezier(0.4, 0, 0.2, 1),
      background-color 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .global-menu__link:hover {
    color: var(--brand, #00ccff);
    background-color: color-mix(in srgb, var(--gm-row-hover) 55%, transparent);
    text-decoration: none;
  }

  .global-menu__link:focus-visible {
    color: var(--accent-blue, #4da3ff);
    background-color: var(--gm-row-hover);
    outline: 1px solid color-mix(in srgb, var(--brand, #00ccff) 45%, transparent);
    outline-offset: 1px;
    text-decoration: none;
  }

  .global-menu__sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip-path: inset(50%);
    border: 0;
    white-space: nowrap;
  }

  @media (prefers-reduced-motion: reduce) {
    .global-menu__backdrop,
    .global-menu__panel,
    .global-menu__overlay,
    .global-menu__bars,
    .global-menu__bars::before,
    .global-menu__bars::after,
    .global-menu__toggle {
      transition: none;
    }

    .global-menu[data-open='true'] .global-menu__backdrop {
      opacity: 1;
    }

    .global-menu__panel {
      transform: translateX(-100%);
    }

    .global-menu[data-open='true'] .global-menu__panel {
      transform: translateX(0);
    }
  }
</style>
