---
interface Props {
  /** Extra class names — e.g. `site-brand--mark` for the small chrome variant. */
  class?: string;
  /** Accessible label for the logo. */
  ariaLabel?: string;
}

const { class: className, ariaLabel = "Vocino" } = Astro.props;

const brandClass = ["site-brand", className].filter(Boolean).join(" ");
---

<div class={brandClass} role="img" aria-label={ariaLabel}>
  <svg
    class="brand-logo"
    width="80"
    height="69"
    viewBox="0 0 250 216"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
    focusable="false"
  >
    <path d="M125 215.909L0 0L250 2.17954e-05L125 215.909Z" fill="currentColor" />
    <path d="M125 71.9697L83.3334 0L166.667 7.26513e-06L125 71.9697Z" fill="var(--bg, #0F1419)" />
  </svg>
</div>

<style>
  .site-brand {
    display: inline-block;
    width: fit-content;
    line-height: 0;
  }

  .site-brand:not(.site-brand--mark) .brand-logo {
    width: 80px;
    max-width: none;
    height: auto;
  }

  @media (max-width: 768px) {
    .site-brand:not(.site-brand--mark) .brand-logo {
      width: 70px;
    }
  }

  @media (max-width: 576px) {
    .site-brand:not(.site-brand--mark) .brand-logo {
      width: 60px;
    }
  }
</style>
