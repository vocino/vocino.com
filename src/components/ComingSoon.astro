---
// Placeholder body for a hub that exists but isn't built out yet.
// Picks up the hub accent via `--section-accent`.
interface Props {
  label: string;
  title: string;
  text?: string;
}

const { label, title, text } = Astro.props;
---

<section class="hub-soon">
  <div class="hub-soon__inner">
    <p class="hub-soon__label">{label}</p>
    <h1 class="hub-soon__title">{title}</h1>
    {text && <p class="hub-soon__text">{text}</p>}
    <p class="hub-soon__status">
      <span class="hub-soon__dot" aria-hidden="true"></span>coming soon<span class="hub-soon__cursor" aria-hidden="true"></span>
    </p>
  </div>
</section>

<style>
  .hub-soon {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 1.5rem;
    box-sizing: border-box;
  }

  .hub-soon__inner {
    max-width: 640px;
    text-align: center;
  }

  .hub-soon__label {
    font-family: var(--font-mono, "Source Code Pro", monospace);
    font-size: 0.8125rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--section-accent, var(--brand));
    margin: 0 0 1.25rem;
  }

  .hub-soon__label::before {
    content: "// ";
    opacity: 0.6;
  }

  .hub-soon__title {
    font-family: "Source Serif 4", Georgia, serif;
    font-size: clamp(2.25rem, 6vw, 3.25rem);
    font-weight: 500;
    line-height: 1.1;
    color: var(--text-primary);
    margin: 0;
    text-wrap: balance;
  }

  .hub-soon__text {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 1.5rem auto 0;
    max-width: 48ch;
    text-wrap: pretty;
  }

  .hub-soon__status {
    font-family: var(--font-mono, "Source Code Pro", monospace);
    font-size: 0.8125rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 2.5rem 0 0;
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
  }

  .hub-soon__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--section-accent, var(--brand));
    box-shadow: 0 0 10px var(--section-accent, var(--brand));
    animation: hubSoonPulse 2s ease-in-out infinite;
  }

  .hub-soon__cursor {
    width: 9px;
    height: 1.05em;
    background: var(--section-accent, var(--brand));
    display: inline-block;
    animation: hubSoonBlink 1s steps(2, start) infinite;
  }

  @keyframes hubSoonPulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
  }

  @keyframes hubSoonBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hub-soon__dot,
    .hub-soon__cursor {
      animation: none;
    }
  }
</style>
