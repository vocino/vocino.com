---
---

<a
  class="social-links__link twitch-status-link"
  href="https://twitch.tv/vocino"
  rel="me"
  aria-label="Twitch"
  target="_blank"
  id="twitch-status-link"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
    <path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714Z"/>
  </svg>
  <span class="twitch-status-indicator" id="twitch-indicator"></span>
</a>

<script>
  async function fetchTwitchStatus() {
    try {
      const response = await fetch('/api/twitch-status');
      const data = (await response.json()) as {
        online?: boolean;
        title?: string | null;
        game?: string | null;
      };

      const indicator = document.getElementById('twitch-indicator');
      const link = document.getElementById('twitch-status-link');

      if (data.online) {
        indicator?.classList.add('online');
        const statusText = data.title || data.game || 'Streaming';
        indicator?.setAttribute('title', `Live: ${statusText}`);
        link?.setAttribute('aria-label', `Twitch - Live: ${statusText}`);
      } else {
        indicator?.classList.remove('online');
        indicator?.setAttribute('title', 'Offline');
        link?.setAttribute('aria-label', 'Twitch - Offline');
      }
    } catch (error) {
      console.error('Failed to fetch Twitch status:', error);
    }
  }

  // Fetch on load
  fetchTwitchStatus();

  // Poll every 60 seconds
  setInterval(fetchTwitchStatus, 60000);
</script>

<style>
  .twitch-status-link {
    position: relative;
  }

  /* Live telemetry dot — sits on icon corner */
  .twitch-status-indicator {
    position: absolute;
    top: 3px;
    right: 3px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: transparent;
    border: 1px solid var(--bg);
    transition:
      opacity 0.3s ease,
      transform 0.3s ease,
      box-shadow 0.3s ease;
    opacity: 0;
    pointer-events: none;
  }

  .twitch-status-indicator.online {
    opacity: 1;
    background: var(--success);
    border-color: rgba(15, 20, 25, 0.95);
    box-shadow:
      0 0 0 1px rgba(61, 250, 154, 0.35),
      0 0 10px rgba(61, 250, 154, 0.65),
      0 0 18px rgba(61, 250, 154, 0.25);
    animation: twitchLivePulse 2s ease-in-out infinite;
  }

  @keyframes twitchLivePulse {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }

    50% {
      opacity: 0.88;
      transform: scale(1.12);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .twitch-status-indicator.online {
      animation: none;
    }
  }
</style>
