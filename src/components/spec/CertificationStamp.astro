---
const text = "VOCINO INDUSTRIES · APPROVED · EST. 1984 · ";
---

<div class="stamp" data-spec="stamp" aria-hidden="true">
  <svg viewBox="0 0 120 120" class="stamp__svg">
    <defs>
      <path
        id="stamp-ring"
        d="M 60,60 m -44,0 a 44,44 0 1,1 88,0 a 44,44 0 1,1 -88,0"
      />
    </defs>

    <circle cx="60" cy="60" r="54" fill="none" stroke="currentColor" stroke-width="2" />
    <circle cx="60" cy="60" r="48" fill="none" stroke="currentColor" stroke-width="0.6" />

    <text class="stamp__text">
      <textPath href="#stamp-ring" startOffset="0">{text + text}</textPath>
    </text>

    <!-- Center triangle (Vocino mark) -->
    <g transform="translate(60 60)">
      <polygon points="-18,-15 18,-15 0,22" fill="currentColor" opacity="0.95" />
      <polygon points="-6,-15 6,-15 0,-7" fill="#0F1419" />
    </g>
  </svg>
</div>

<style lang="scss">
  .stamp {
    color: var(--stamp-red);
    transform: rotate(-7deg);
    opacity: 0.92;
    filter: drop-shadow(0 0 0 transparent);
    mix-blend-mode: screen;
  }
  .stamp__svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .stamp__text {
    font-family: "Source Code Pro", monospace;
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    fill: currentColor;
  }
</style>
