---
import SpecModule from "./SpecModule.astro";
---

<SpecModule label="I/O Flow · Process Diagram" index={4} area="flow">
  <div class="flow">
    <div class="flow__col flow__col--in">
      <span class="flow__cap">Input</span>
      <ul class="flow__list">
        <li>Coffee</li>
        <li>Curiosity</li>
        <li>Pixels</li>
      </ul>
    </div>

    <svg class="flow__arrow" viewBox="0 0 80 16" aria-hidden="true" preserveAspectRatio="none">
      <line x1="0" y1="8" x2="72" y2="8" stroke="currentColor" stroke-width="1" />
      <polygon points="80,8 70,3 70,13" fill="currentColor" />
    </svg>

    <div class="flow__col flow__col--proc">
      <span class="flow__cap">Process</span>
      <div class="flow__proc">
        <span class="flow__bracket">[</span>
        <span class="flow__proc-name">TRAVIS<span class="flow__dot">.</span>EXE</span>
        <span class="flow__bracket">]</span>
      </div>
      <span class="flow__proc-meta">v37.0 · running</span>
    </div>

    <svg class="flow__arrow" viewBox="0 0 80 16" aria-hidden="true" preserveAspectRatio="none">
      <line x1="0" y1="8" x2="72" y2="8" stroke="currentColor" stroke-width="1" />
      <polygon points="80,8 70,3 70,13" fill="currentColor" />
    </svg>

    <div class="flow__col flow__col--out">
      <span class="flow__cap">Output</span>
      <ul class="flow__list">
        <li>Software</li>
        <li>Tchotchkes</li>
        <li>Vibes</li>
      </ul>
    </div>
  </div>
</SpecModule>

<style lang="scss">
  .flow {
    height: 100%;
    display: grid;
    grid-template-columns: 1fr auto 1.1fr auto 1fr;
    align-items: stretch;
    gap: clamp(6px, 1.6vmin, 18px);
    min-width: 0;
  }

  .flow__col {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: clamp(4px, 0.8vmin, 10px);
    padding: clamp(4px, 1vmin, 12px) clamp(6px, 1.2vmin, 14px);
    border: 1px solid var(--ink-faint);
    min-width: 0;
  }
  .flow__col--proc {
    border-color: var(--brand);
    align-items: center;
    text-align: center;
  }

  .flow__cap {
    font-family: "Source Code Pro", monospace;
    font-size: var(--spec-label-size);
    text-transform: uppercase;
    letter-spacing: var(--spec-tracking);
    color: var(--ink-dim);
  }

  .flow__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: clamp(1px, 0.4vmin, 4px);
    font-family: "Source Sans 3", sans-serif;
    font-size: var(--spec-data-size);
    font-weight: 600;
    color: var(--ink);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .flow__list li::before {
    content: "▪ ";
    color: var(--brand);
  }

  .flow__arrow {
    align-self: center;
    width: 100%;
    height: clamp(8px, 1.6vmin, 16px);
    color: var(--brand);
  }

  .flow__proc {
    font-family: "Source Code Pro", monospace;
    font-size: clamp(0.85rem, 2vmin, 1.4rem);
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--ink);
    display: flex;
    align-items: baseline;
    gap: 0.15em;
  }
  .flow__bracket {
    color: var(--brand);
    font-weight: 400;
  }
  .flow__dot { color: var(--stamp-red); }

  .flow__proc-meta {
    font-family: "Source Code Pro", monospace;
    font-size: var(--spec-label-size);
    text-transform: uppercase;
    letter-spacing: var(--spec-tracking);
    color: var(--ink-dim);
  }

  // Phone: stack vertically with downward arrows
  @media (max-width: 540px), (max-aspect-ratio: 4/5) {
    .flow {
      grid-template-columns: minmax(0, 1fr);
      grid-auto-rows: minmax(0, 1fr);
      gap: clamp(2px, 0.8vmin, 8px);
    }
    .flow__arrow {
      transform: rotate(90deg);
      height: clamp(8px, 1.4vmin, 14px);
    }
  }
</style>
