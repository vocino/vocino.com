---
// Single source of truth for the Vocino logo geometry.
// Color comes from the parent's `color` (the outer V is `currentColor`);
// sizing comes from the global `.site-brand .brand-logo` rules.
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const cls = ["brand-logo", className].filter(Boolean).join(" ");
---

<svg
  class={cls}
  width="80"
  height="69"
  viewBox="0 0 250 216"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  focusable="false"
>
  <path d="M125 215.909L0 0L250 2.17954e-05L125 215.909Z" fill="currentColor" />
  <path d="M125 71.9697L83.3334 0L166.667 7.26513e-06L125 71.9697Z" fill="var(--bg, #0F1419)" />
</svg>
