---
import HubLayout from '../layouts/HubLayout.astro';
import ComingSoon from '../components/ComingSoon.astro';
import { getHubBreadcrumb, getHubBySlug } from '../data/hubs';

const hub = getHubBySlug('bg3');
---

<HubLayout
  title={hub.name}
  hubName={hub.name}
  description={hub.description}
  canonicalPath={`/${hub.slug}`}
  breadcrumb={getHubBreadcrumb(hub)}
  imagePath={hub.imagePath}
  accent={hub.accent}
  noindex={!hub.indexable}
>
  <ComingSoon
    label="BG3"
    title="Baldur's Gate 3"
    text="Builds, run notes, and honour-mode guides — kept here mostly for me, shared in case they're useful to you."
  />
</HubLayout>
