---
import GlobalHamburgerMenu from "../components/GlobalHamburgerMenu.astro";
import BG3Checklist from "../components/bg3/BG3Checklist.astro";
import {
  dontLeaveByAct,
  beforeLongRest,
  afterLevelUp,
  beforeLeaving,
  thayReading,
  approvalGates
} from "../data/bg3/now";
import { levels } from "../data/bg3/levels";
import { gearByAct } from "../data/bg3/gear";
import { companions, loreRules } from "../data/bg3/coven";
import { setupSections } from "../data/bg3/setup";
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BG3 Necromancer Guide</title>
  <meta
    name="description"
    content="Mobile-first second-screen companion for a Baldur's Gate 3 necromancer run."
  />
  <style>
    :root {
      --bg: #0b0b0c;
      --surface: #121216;
      --surface-2: #18181d;
      --text: #e8e8e8;
      --muted: #9b9ba3;
      --accent: #8b5cf6;
      --accent-soft: #2a1d45;
      --border: #262630;
      --tag-lore: #2a1d45;
      --tag-lore-text: #d7c4ff;
      --tag-combat: #3a1d1d;
      --tag-combat-text: #ffb7a4;
      --tag-both: #1f2a3a;
      --tag-both-text: #a4c7ff;
    }

    * {
      box-sizing: border-box;
    }

    html,
    body {
      margin: 0;
      padding: 0;
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Inter, "Helvetica Neue", Arial, sans-serif;
      font-size: 16px;
      line-height: 1.45;
    }

    body {
      min-height: 100vh;
    }

    .app {
      width: 100%;
      max-width: 480px;
      margin: 0 auto;
      padding: 12px 12px 88px;
    }

    h1,
    h2,
    h3 {
      margin: 0;
      font-size: 20px;
      line-height: 1.25;
      letter-spacing: 0.01em;
    }

    h1 {
      margin-bottom: 8px;
    }

    p {
      margin: 0;
    }

    .intro {
      color: var(--muted);
      margin-bottom: 12px;
    }

    .controls {
      display: flex;
      gap: 8px;
      margin: 0 0 12px;
    }

    .button {
      min-height: 44px;
      border: 1px solid var(--border);
      border-radius: 12px;
      background: var(--surface);
      color: var(--text);
      padding: 0 14px;
      font: inherit;
      cursor: pointer;
    }

    .button:hover,
    .button:focus-visible {
      border-color: var(--accent);
      outline: none;
    }

    .panel {
      display: none;
      flex-direction: column;
      gap: 10px;
      margin-top: 10px;
    }

    .panel[aria-hidden="false"] {
      display: flex;
    }

    details {
      border: 1px solid var(--border);
      border-radius: 12px;
      background: var(--surface);
      overflow: hidden;
    }

    summary {
      list-style: none;
      min-height: 44px;
      display: flex;
      align-items: center;
      padding: 10px 14px;
      cursor: pointer;
      font-weight: 600;
      position: relative;
      gap: 8px;
    }

    summary::-webkit-details-marker {
      display: none;
    }

    summary::after {
      content: "+";
      margin-left: auto;
      color: var(--accent);
      font-size: 20px;
      line-height: 1;
    }

    details[open] > summary::after {
      content: "-";
    }

    .summary-title {
      flex: 1 1 auto;
      min-width: 0;
    }

    .count {
      color: var(--muted);
      font-weight: 400;
      font-size: 0.85rem;
      margin-left: 8px;
      white-space: nowrap;
    }

    .count[data-complete="true"] {
      color: var(--accent);
    }

    .section-body {
      padding: 0 14px 12px;
      border-top: 1px solid var(--border);
      background: var(--surface-2);
    }

    .section-body p + p,
    .section-body ul + p,
    .section-body p + ul {
      margin-top: 8px;
    }

    .section-intro {
      color: var(--muted);
      margin: 10px 0 4px;
    }

    .checklist {
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .checklist li + li {
      border-top: 1px solid rgba(139, 92, 246, 0.17);
    }

    .check {
      min-height: 44px;
      display: grid;
      grid-template-columns: 28px 1fr;
      align-items: center;
      gap: 10px;
      padding: 8px 0;
      cursor: pointer;
    }

    .check input {
      width: 22px;
      height: 22px;
      accent-color: var(--accent);
      margin: 0;
    }

    .check small {
      color: var(--muted);
      display: block;
      margin-top: 2px;
    }

    .check-label {
      display: inline;
    }

    .tag {
      display: inline-block;
      vertical-align: baseline;
      margin-left: 6px;
      padding: 1px 8px;
      border-radius: 999px;
      font-size: 0.7rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      line-height: 1.6;
    }

    .tag-lore {
      background: var(--tag-lore);
      color: var(--tag-lore-text);
    }

    .tag-combat {
      background: var(--tag-combat);
      color: var(--tag-combat-text);
    }

    .tag-both {
      background: var(--tag-both);
      color: var(--tag-both-text);
    }

    .lore-fit {
      display: inline-block;
      margin-left: 8px;
      padding: 1px 8px;
      border-radius: 999px;
      font-size: 0.7rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      line-height: 1.6;
    }

    .lore-fit-high {
      background: var(--tag-lore);
      color: var(--tag-lore-text);
    }

    .lore-fit-medium {
      background: var(--tag-both);
      color: var(--tag-both-text);
    }

    .lore-fit-low {
      background: var(--surface-2);
      color: var(--muted);
      border: 1px solid var(--border);
    }

    .lore-fit-hostile {
      background: var(--tag-combat);
      color: var(--tag-combat-text);
    }

    .companion-meta {
      color: var(--muted);
      font-size: 0.85rem;
      margin: 4px 0 8px;
    }

    .companion-notes {
      margin: 0;
      padding-left: 1.1rem;
    }

    .companion-notes li + li {
      margin-top: 4px;
    }

    .pill-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .pill {
      min-height: 44px;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--text);
      padding: 0 14px;
      font: inherit;
      cursor: pointer;
    }

    .pill[aria-pressed="true"] {
      background: var(--accent-soft);
      border-color: var(--accent);
      color: #f3ecff;
    }

    .muted {
      color: var(--muted);
    }

    .row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 8px;
    }

    .badge {
      color: var(--muted);
      font-size: 0.88rem;
    }

    .tabbar {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      border-top: 1px solid var(--border);
      background: rgba(11, 11, 12, 0.97);
      backdrop-filter: blur(10px);
    }

    .tabbar-inner {
      max-width: 480px;
      margin: 0 auto;
      padding: 8px 12px calc(8px + env(safe-area-inset-bottom));
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 8px;
    }

    .tab {
      min-height: 44px;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--text);
      font: inherit;
      font-size: 0.82rem;
      cursor: pointer;
      padding: 0 4px;
    }

    .tab[aria-selected="true"] {
      border-color: var(--accent);
      background: var(--accent-soft);
      color: #f3ecff;
    }

    .hidden {
      display: none !important;
    }
  </style>
</head>
<body class="site-root">
  <div class="site-chrome">
    <GlobalHamburgerMenu />
  </div>
  <main class="app">
    <h1>BG3 Necromancer Guide</h1>
    <p class="intro">Mobile-first second-screen companion for a Custom Tav Human Wizard Necromancer.</p>

    <div class="controls">
      <button id="show-setup-button" class="button hidden" type="button">Show Setup Tab</button>
      <button id="reset-button" class="button" type="button">Reset Checks</button>
    </div>

    <section id="now-panel" class="panel" data-tab-panel="now" aria-hidden="false">
      <details data-section-id="now-act-selector" data-no-count>
        <summary><span class="summary-title">Spot Check</span></summary>
        <div class="section-body">
          <p class="section-intro">Act selector</p>
          <div class="pill-row" role="radiogroup" aria-label="Act selector">
            <button type="button" class="pill" data-act="act1" aria-pressed="true">Act 1</button>
            <button type="button" class="pill" data-act="act2" aria-pressed="false">Act 2</button>
            <button type="button" class="pill" data-act="act3" aria-pressed="false">Act 3</button>
          </div>
        </div>
      </details>

      <details data-section-id="now-dont-leave">
        <summary><span class="summary-title">Don’t Leave Act Without</span></summary>
        <div class="section-body">
          <div data-act-list="act1">
            <BG3Checklist items={dontLeaveByAct.act1} />
          </div>
          <div data-act-list="act2" class="hidden">
            <BG3Checklist items={dontLeaveByAct.act2} />
          </div>
          <div data-act-list="act3" class="hidden">
            <BG3Checklist items={dontLeaveByAct.act3} />
          </div>
        </div>
      </details>

      <details data-section-id={beforeLongRest.id}>
        <summary><span class="summary-title">{beforeLongRest.title}</span></summary>
        <div class="section-body">
          <BG3Checklist items={beforeLongRest.items} />
        </div>
      </details>

      <details data-section-id={thayReading.id}>
        <summary><span class="summary-title">{thayReading.title}</span></summary>
        <div class="section-body">
          {thayReading.intro && <p class="section-intro">{thayReading.intro}</p>}
          <BG3Checklist items={thayReading.items} />
        </div>
      </details>

      <details data-section-id={approvalGates.id}>
        <summary><span class="summary-title">{approvalGates.title}</span></summary>
        <div class="section-body">
          <BG3Checklist items={approvalGates.items} />
        </div>
      </details>

      <details data-section-id={afterLevelUp.id}>
        <summary><span class="summary-title">{afterLevelUp.title}</span></summary>
        <div class="section-body">
          <BG3Checklist items={afterLevelUp.items} />
        </div>
      </details>

      <details data-section-id={beforeLeaving.id}>
        <summary><span class="summary-title">{beforeLeaving.title}</span></summary>
        <div class="section-body">
          <BG3Checklist items={beforeLeaving.items} />
        </div>
      </details>
    </section>

    <section id="levels-panel" class="panel" data-tab-panel="levels" aria-hidden="true">
      {levels.map((level) => (
        <details data-section-id={level.id}>
          <summary><span class="summary-title">{level.title}</span></summary>
          <div class="section-body">
            {level.intro && <p class="section-intro">{level.intro}</p>}
            <BG3Checklist items={level.items} />
          </div>
        </details>
      ))}
    </section>

    <section id="gear-panel" class="panel" data-tab-panel="gear" aria-hidden="true">
      {gearByAct.map((section) => (
        <details data-section-id={section.id} data-no-count>
          <summary><span class="summary-title">{section.title}</span></summary>
          <div class="section-body">
            <BG3Checklist items={section.items} />
          </div>
        </details>
      ))}
    </section>

    <section id="coven-panel" class="panel" data-tab-panel="coven" aria-hidden="true">
      {companions.map((c) => (
        <details data-section-id={c.id} data-no-count>
          <summary>
            <span class="summary-title">{c.name}</span>
            <span class={`lore-fit lore-fit-${c.loreFit}`}>{c.loreFit}</span>
          </summary>
          <div class="section-body">
            <p class="companion-meta">{c.recruit}</p>
            <ul class="companion-notes">
              {c.notes.map((line) => <li>{line}</li>)}
            </ul>
          </div>
        </details>
      ))}

      <details data-section-id={loreRules.id} data-no-count>
        <summary><span class="summary-title">{loreRules.title}</span></summary>
        <div class="section-body">
          {loreRules.intro && <p class="section-intro">{loreRules.intro}</p>}
          <BG3Checklist items={loreRules.items} />
        </div>
      </details>
    </section>

    <section id="setup-panel" class="panel" data-tab-panel="setup" aria-hidden="true">
      {setupSections.map((section) => (
        <details data-section-id={section.id} data-no-count>
          <summary><span class="summary-title">{section.title}</span></summary>
          <div class="section-body">
            {section.intro && <p class="section-intro">{section.intro}</p>}
            <BG3Checklist items={section.items} />
          </div>
        </details>
      ))}
    </section>
  </main>

  <nav class="tabbar" aria-label="Guide tabs">
    <div class="tabbar-inner">
      <button class="tab" type="button" data-tab="now" aria-selected="true">Now</button>
      <button class="tab" type="button" data-tab="levels" aria-selected="false">Levels</button>
      <button class="tab" type="button" data-tab="gear" aria-selected="false">Gear</button>
      <button class="tab" type="button" data-tab="coven" aria-selected="false">Coven</button>
      <button class="tab" type="button" data-tab="setup" aria-selected="false">Setup</button>
    </div>
  </nav>

  <script is:inline>
    (() => {
      const storageKey = "bg3-necro-guide-v2";
      const legacyKey = "bg3-necro-guide-v1";
      const defaultState = {
        activeTab: "now",
        act: "act1",
        checks: {},
        openSections: {},
        setupHidden: false
      };

      // One-shot migration from v1 → v2 so mid-playthrough progress survives.
      try {
        const legacy = localStorage.getItem(legacyKey);
        if (legacy && !localStorage.getItem(storageKey)) {
          const parsed = JSON.parse(legacy);
          localStorage.setItem(storageKey, JSON.stringify({
            ...defaultState,
            ...parsed,
            checks: parsed.checks || {},
            openSections: parsed.openSections || {}
          }));
          localStorage.removeItem(legacyKey);
        }
      } catch (_error) {
        // Ignore — legacy state will simply not migrate.
      }

      const loadState = () => {
        try {
          const raw = localStorage.getItem(storageKey);
          if (!raw) return { ...defaultState };
          const parsed = JSON.parse(raw);
          return {
            ...defaultState,
            ...parsed,
            checks: parsed.checks || {},
            openSections: parsed.openSections || {}
          };
        } catch (_error) {
          return { ...defaultState };
        }
      };

      const state = loadState();

      const saveState = () => {
        localStorage.setItem(storageKey, JSON.stringify(state));
      };

      const tabButtons = Array.from(document.querySelectorAll("[data-tab]"));
      const panels = Array.from(document.querySelectorAll("[data-tab-panel]"));
      const sectionDetails = Array.from(document.querySelectorAll("details[data-section-id]"));
      const setupTabButton = document.querySelector('[data-tab="setup"]');
      const showSetupButton = document.getElementById("show-setup-button");
      const knownTabs = new Set(["now", "levels", "gear", "coven", "setup"]);

      // X / Y completion counters only on Now and Levels panels.
      const counterPanels = new Set(["now", "levels"]);
      const counterSections = sectionDetails.filter((detail) => {
        if (detail.dataset.noCount !== undefined) return false;
        const panel = detail.closest("[data-tab-panel]");
        return panel instanceof HTMLElement && counterPanels.has(panel.dataset.tabPanel || "");
      });

      counterSections.forEach((detail) => {
        const summary = detail.querySelector("summary");
        if (!summary || summary.querySelector(".count")) return;
        const count = document.createElement("span");
        count.className = "count";
        summary.appendChild(count);
      });

      const refreshCounts = () => {
        counterSections.forEach((detail) => {
          const total = detail.querySelectorAll('input[type="checkbox"]').length;
          const done = detail.querySelectorAll('input[type="checkbox"]:checked').length;
          const count = detail.querySelector(".count");
          if (!count || total === 0) return;
          count.textContent = `${done} / ${total}`;
          count.dataset.complete = done === total ? "true" : "false";
        });
      };

      const applyTab = () => {
        if (state.setupHidden && state.activeTab === "setup") {
          state.activeTab = "now";
        }
        tabButtons.forEach((button) => {
          const selected = button.dataset.tab === state.activeTab;
          button.setAttribute("aria-selected", selected ? "true" : "false");
        });
        panels.forEach((panel) => {
          const selected = panel.dataset.tabPanel === state.activeTab;
          panel.setAttribute("aria-hidden", selected ? "false" : "true");
        });
      };

      const applyAct = () => {
        document.querySelectorAll("[data-act]").forEach((button) => {
          const pressed = button.dataset.act === state.act;
          button.setAttribute("aria-pressed", pressed ? "true" : "false");
        });
        document.querySelectorAll("[data-act-list]").forEach((list) => {
          const matches = list.dataset.actList === state.act;
          list.classList.toggle("hidden", !matches);
        });
      };

      const applySetupVisibility = () => {
        if (!setupTabButton || !showSetupButton) return;
        setupTabButton.classList.toggle("hidden", state.setupHidden);
        showSetupButton.classList.toggle("hidden", !state.setupHidden);
        if (state.setupHidden && state.activeTab === "setup") {
          state.activeTab = "now";
        }
      };

      const resolveTabFromTarget = (target) => {
        if (!target) return null;
        if (knownTabs.has(target)) return target;
        if (target.startsWith("level-") || /^l\d+-/.test(target)) return "levels";
        if (target.startsWith("gear-")) return "gear";
        if (target.startsWith("coven-") || target.startsWith("lore-")) return "coven";
        if (
          target.startsWith("setup-") ||
          target.startsWith("abi-") ||
          target.startsWith("skill-") ||
          target.startsWith("cantrip-") ||
          target.startsWith("spell-")
        ) {
          return "setup";
        }
        if (
          target.startsWith("now-") ||
          target.startsWith("act") ||
          target.startsWith("rest-") ||
          target.startsWith("levelup-") ||
          target.startsWith("leave-") ||
          target.startsWith("thay-") ||
          target.startsWith("approval-")
        ) {
          return "now";
        }
        return null;
      };

      const applyHashRoute = () => {
        const target = window.location.hash.replace(/^#/, "").trim();
        if (!target) return;

        const tab = resolveTabFromTarget(target);
        if (tab) {
          if (tab === "setup") {
            state.setupHidden = false;
            state.checks["setup-complete"] = false;
          }
          state.activeTab = tab;
        }

        const section = document.getElementById(target);
        if (section instanceof HTMLDetailsElement) {
          section.open = true;
          state.openSections[target] = true;
        }

        applySetupVisibility();
        applyTab();
        saveState();
      };

      tabButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const tab = button.dataset.tab;
          if (!tab) return;
          state.activeTab = tab;
          applyTab();
          window.history.replaceState(null, "", `#${tab}`);
          saveState();
        });
      });

      document.querySelectorAll("[data-act]").forEach((button) => {
        button.addEventListener("click", () => {
          const act = button.dataset.act;
          if (!act) return;
          state.act = act;
          applyAct();
          saveState();
        });
      });

      document.querySelectorAll("[data-check-id]").forEach((checkbox) => {
        const key = checkbox.dataset.checkId;
        if (!key) return;
        checkbox.checked = Boolean(state.checks[key]);
        checkbox.addEventListener("change", () => {
          state.checks[key] = checkbox.checked;
          if (key === "setup-complete") {
            state.setupHidden = checkbox.checked;
            applySetupVisibility();
            applyTab();
          }
          refreshCounts();
          saveState();
        });
      });

      sectionDetails.forEach((detail) => {
        const key = detail.dataset.sectionId;
        if (!key) return;
        if (!detail.id) {
          detail.id = key;
        }
        detail.open = Boolean(state.openSections[key]);
        detail.addEventListener("toggle", () => {
          state.openSections[key] = detail.open;
          saveState();
        });
      });

      showSetupButton?.addEventListener("click", () => {
        state.setupHidden = false;
        state.checks["setup-complete"] = false;
        const setupCompleteCheck = document.querySelector('[data-check-id="setup-complete"]');
        if (setupCompleteCheck instanceof HTMLInputElement) setupCompleteCheck.checked = false;
        state.activeTab = "setup";
        applySetupVisibility();
        applyTab();
        refreshCounts();
        window.history.replaceState(null, "", "#setup");
        saveState();
      });

      document.getElementById("reset-button")?.addEventListener("click", () => {
        const shouldReset = window.confirm("Reset all checkboxes and section states?");
        if (!shouldReset) return;
        state.checks = {};
        state.openSections = {};
        state.setupHidden = false;
        state.activeTab = "now";
        state.act = "act1";
        localStorage.removeItem(storageKey);
        window.location.reload();
      });

      applySetupVisibility();
      applyAct();
      applyTab();
      applyHashRoute();
      refreshCounts();
      window.addEventListener("hashchange", applyHashRoute);
      saveState();
    })();
  </script>
</body>
</html>
