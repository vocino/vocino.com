---
import BaseLayout from "../layouts/BaseLayout.astro";
import BG3Checklist from "../components/bg3/BG3Checklist.astro";
import {
  dontLeaveByAct,
  criticalQuests,
  combatLoop,
  beforeLongRest,
  afterLevelUp,
  beforeLeaving,
  thayReading,
  approvalGates,
  triangleOfDeath
} from "../data/bg3/now";
import { coreParty, loreRules } from "../data/bg3/coven";
import { builds } from "../data/bg3/builds/index";

const pcBuild = builds.find((b) => b.id === "pc-necromancer")!;
const glance = pcBuild.glance;
const covenBuilds = builds.filter((b) => b.id !== "pc-necromancer");

const sections = [
  { id: "setup",  label: "Setup" },
  { id: "levels", label: "Levels" },
  { id: "gear",   label: "Gear" },
  { id: "quests", label: "Quests & Lore" },
  { id: "combat", label: "Combat & Rest" },
  { id: "coven",  label: "Coven" }
];
---

<BaseLayout
  title="BG3 Patch 8 Deathreaper Guide — Vocino"
  description="Patch 8 second-screen companion: Human Death Domain Cleric who dual-wields hand crossbows. 8 Cleric / 2 Necromancy Wizard / 2 Spore Druid. No undead armies."
>
  <section class="bg3-section">
    <div class="bg3-app">
      <header class="bg3-header">
        <span class="bg3-eyebrow">guide · baldur's gate 3</span>
        <h1 class="bg3-title">Deathreaper Guide</h1>
        <span class="bg3-accent-bar" aria-hidden="true"></span>
        <p class="bg3-subtitle">Patch 8 · Human Death Domain Cleric · Triangle of Death cantrips, dual hand crossbows, no undead armies.</p>
      </header>

      {glance && (
        <aside class="bg3-glance" aria-label="Build at a glance">
          <div class="bg3-glance-row">
            <span class="bg3-glance-label">Split</span>
            <span class="bg3-glance-value bg3-glance-split">
              {glance.split.split('/').map((seg, i) => (
                <>
                  <span
                    class="bg3-glance-segment"
                    data-count={seg.trim()}
                    style={`--class-color: var(--class-${(glance.classes[i] || '').toLowerCase()})`}
                  >{glance.classes[i]}</span>
                  {i < glance.classes.length - 1 && <span class="bg3-glance-sep">·</span>}
                </>
              ))}
            </span>
          </div>
          <div class="bg3-glance-row">
            <span class="bg3-glance-label">Stat</span>
            <span class="bg3-glance-value"><strong>{glance.dominantStat}</strong></span>
          </div>
          <div class="bg3-glance-row">
            <span class="bg3-glance-label">Role</span>
            <span class="bg3-glance-value">{pcBuild.role}</span>
          </div>
          <div class="bg3-glance-row">
            <span class="bg3-glance-label">Feats</span>
            <span class="bg3-glance-value">{glance.feats.join(' · ')}</span>
          </div>
        </aside>
      )}

      <aside id={triangleOfDeath.id} class="bg3-triangle" aria-label={triangleOfDeath.title}>
        <h2 class="bg3-triangle-title">{triangleOfDeath.title}</h2>
        {triangleOfDeath.intro && <p class="bg3-triangle-intro">{triangleOfDeath.intro}</p>}
        <div class="bg3-triangle-rows">
          {triangleOfDeath.rows.map((row) => (
            <div class="bg3-triangle-row">
              <span class="bg3-triangle-stat">{row.stat}</span>
              <span class="bg3-triangle-cantrip">{row.cantrip}</span>
            </div>
          ))}
        </div>
      </aside>

      <nav class="bg3-toc" aria-label="Jump to section">
        {sections.map((s) => (
          <a class="bg3-toc-link" href={`#${s.id}`}>{s.label}</a>
        ))}
      </nav>

      <section id="setup" class="bg3-page-section">
        <h2 class="bg3-h2">Character Creation</h2>
        {pcBuild.setup
          .filter((section) => section.id !== "setup-complete-section")
          .map((section) => (
            <article class="bg3-card">
              <h3 class="bg3-card-title">{section.title}</h3>
              {section.intro && <p class="bg3-intro">{section.intro}</p>}
              <BG3Checklist items={section.items} idPrefix={pcBuild.shortId} />
            </article>
          ))}
      </section>

      <section id="levels" class="bg3-page-section">
        <h2 class="bg3-h2">Level Progression</h2>
        <div class="bg3-level-grid">
          {pcBuild.levels.map((level) => (
            <article class:list={["bg3-card bg3-level-card", level.milestone && "bg3-card--milestone"]}>
              <header class="bg3-card-header">
                <h3 class="bg3-card-title">{level.title}</h3>
                {level.levelClass && (
                  <span class="bg3-class-chip" data-class={level.levelClass}>{level.levelClass}</span>
                )}
              </header>
              {level.intro && <p class="bg3-intro">{level.intro}</p>}
              <BG3Checklist items={level.items} idPrefix={pcBuild.shortId} />
            </article>
          ))}
        </div>
      </section>

      <section id="gear" class="bg3-page-section">
        <h2 class="bg3-h2">Gear by Act</h2>
        <div class="bg3-gear-grid">
          {pcBuild.gear.map((section) => (
            <article class="bg3-card bg3-gear-card">
              <h3 class="bg3-card-title">{section.title}</h3>
              <BG3Checklist items={section.items} idPrefix={pcBuild.shortId} />
            </article>
          ))}
        </div>
      </section>

      <section id="quests" class="bg3-page-section">
        <h2 class="bg3-h2">Quests & Lore</h2>
        <article class="bg3-card">
          <h3 class="bg3-card-title">{criticalQuests.title}</h3>
          {criticalQuests.intro && <p class="bg3-intro">{criticalQuests.intro}</p>}
          <BG3Checklist items={criticalQuests.items} />
        </article>
        <article class="bg3-card">
          <h3 class="bg3-card-title">{loreRules.title}</h3>
          {loreRules.intro && <p class="bg3-intro">{loreRules.intro}</p>}
          <BG3Checklist items={loreRules.items} />
        </article>
        <article class="bg3-card">
          <h3 class="bg3-card-title">{thayReading.title}</h3>
          {thayReading.intro && <p class="bg3-intro">{thayReading.intro}</p>}
          <BG3Checklist items={thayReading.items} />
        </article>
      </section>

      <section id="combat" class="bg3-page-section">
        <h2 class="bg3-h2">Combat & Rest</h2>
        <article class="bg3-card">
          <h3 class="bg3-card-title">{combatLoop.title}</h3>
          {combatLoop.intro && <p class="bg3-intro">{combatLoop.intro}</p>}
          <BG3Checklist items={combatLoop.items} />
        </article>
        <article class="bg3-card">
          <h3 class="bg3-card-title">Don't Leave Act Without</h3>
          <div class="bg3-act-stack">
            <div class="bg3-act-block">
              <h4 class="bg3-h4">Act 1</h4>
              <BG3Checklist items={dontLeaveByAct.act1} />
            </div>
            <div class="bg3-act-block">
              <h4 class="bg3-h4">Act 2</h4>
              <BG3Checklist items={dontLeaveByAct.act2} />
            </div>
            <div class="bg3-act-block">
              <h4 class="bg3-h4">Act 3</h4>
              <BG3Checklist items={dontLeaveByAct.act3} />
            </div>
          </div>
        </article>
        <article class="bg3-card">
          <h3 class="bg3-card-title">{beforeLongRest.title}</h3>
          <BG3Checklist items={beforeLongRest.items} />
        </article>
        <article class="bg3-card">
          <h3 class="bg3-card-title">{beforeLeaving.title}</h3>
          <BG3Checklist items={beforeLeaving.items} />
        </article>
        <article class="bg3-card">
          <h3 class="bg3-card-title">{afterLevelUp.title}</h3>
          <BG3Checklist items={afterLevelUp.items} />
        </article>
        <article class="bg3-card">
          <h3 class="bg3-card-title">{approvalGates.title}</h3>
          <BG3Checklist items={approvalGates.items} />
        </article>
      </section>

      <section id="coven" class="bg3-page-section">
        <h2 class="bg3-h2">Coven</h2>
        <article class="bg3-card">
          <h3 class="bg3-card-title">{coreParty.title}</h3>
          {coreParty.intro && <p class="bg3-intro">{coreParty.intro}</p>}
          <BG3Checklist items={coreParty.items} />
        </article>
        <div class="bg3-build-grid">
          {covenBuilds.map((build) => (
            <article class="bg3-build-card">
              <div class="bg3-build-card-header">
                <h3 class="bg3-build-card-name">{build.name}</h3>
                {build.loreFit && <span class={`lore-fit lore-fit-${build.loreFit}`}>{build.loreFit}</span>}
              </div>
              <p class="bg3-build-card-class">{build.className}</p>
              <p class="bg3-build-card-role">{build.role}</p>
              <p class="bg3-build-card-summary">{build.summary}</p>
              {build.recruit && <p class="companion-meta">{build.recruit}</p>}
            </article>
          ))}
        </div>
      </section>

      <div class="bg3-footer-controls">
        <button id="reset-button" class="bg3-button" type="button">Reset checkboxes</button>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const storageKey = "bg3-deathreaper-guide-v5";
      const legacyKeys = ["bg3-necro-guide-v4", "bg3-necro-guide-v3", "bg3-necro-guide-v2", "bg3-necro-guide-v1"];

      // Migrate v1–v4 → v5 by carrying over only the `checks` map.
      try {
        if (!localStorage.getItem(storageKey)) {
          for (const k of legacyKeys) {
            const raw = localStorage.getItem(k);
            if (!raw) continue;
            const old = JSON.parse(raw);
            localStorage.setItem(storageKey, JSON.stringify({ checks: old.checks || {} }));
            break;
          }
        }
        for (const k of legacyKeys) {
          try { localStorage.removeItem(k); } catch (_e) {}
        }
      } catch (_e) {}

      const loadState = () => {
        try {
          const raw = localStorage.getItem(storageKey);
          if (!raw) return { checks: {} };
          const parsed = JSON.parse(raw);
          return { checks: parsed.checks || {} };
        } catch (_e) {
          return { checks: {} };
        }
      };

      const state = loadState();
      const save = () => localStorage.setItem(storageKey, JSON.stringify(state));

      document.querySelectorAll("[data-check-id]").forEach((cb) => {
        const key = cb.dataset.checkId;
        if (!key) return;
        cb.checked = Boolean(state.checks[key]);
        cb.addEventListener("change", () => {
          state.checks[key] = cb.checked;
          save();
        });
      });

      document.getElementById("reset-button")?.addEventListener("click", () => {
        if (!window.confirm("Reset all checkboxes?")) return;
        localStorage.removeItem(storageKey);
        window.location.reload();
      });
    })();
  </script>
</BaseLayout>
