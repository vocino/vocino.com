---
import BaseLayout from "../layouts/BaseLayout.astro";
import BG3Checklist from "../components/bg3/BG3Checklist.astro";
import {
  darkUrgeOrigin,
  withersTiming,
  loreByAct,
  gearByAct,
  pitfalls
} from "../data/bg3/now";
import { partyOverview, partyAlternates, scholarStance } from "../data/bg3/party";
import { builds } from "../data/bg3/builds/index";

const buildById = (id: string) => builds.find((b) => b.id === id)!;
const coreBuilds = [
  buildById("pc-shadow-sorcerer"),
  buildById("shadowheart"),
  buildById("gale")
];
const flexBuilds = [buildById("astarion"), buildById("laezel")];
const alternateBuilds = [buildById("minthara"), buildById("karlach"), buildById("jaheira")];

const sections = [
  { id: "party",  label: "Party" },
  { id: "origin", label: "Origin" },
  { id: "builds", label: "Builds" },
  { id: "lore",   label: "Lore" },
  { id: "gear",   label: "Gear" },
  { id: "avoid",  label: "Pitfalls" }
];
---

<BaseLayout
  title="BG3 Dark Urge Shadow Sorcerer Necrotic Party — Vocino"
  description="Lore-first Dark Urge run. Single-class party: Shadow Sorcerer Tav, Death Domain Cleric, Necromancy Wizard, plus a flex slot. Balanced difficulty, no holy magic."
>
  <section class="bg3-section">
    <div class="bg3-app">
      <header class="bg3-header">
        <span class="bg3-eyebrow">guide · baldur's gate 3 · dark urge</span>
        <h1 class="bg3-title">Shadow Sorcerer Necrotic Party</h1>
        <span class="bg3-accent-bar" aria-hidden="true"></span>
        <p class="bg3-subtitle">
          Lore-first Dark Urge. Single-class party, balanced difficulty, no holy magic.
          Shadow Sorcerer Tav · Death Domain Cleric · Necromancy Wizard · Astarion or Lae'zel flex · Minthara optional Oathbreaker.
        </p>
      </header>

      <nav class="bg3-toc" aria-label="Jump to section">
        {sections.map((s) => (
          <a class="bg3-toc-link" href={`#${s.id}`}>{s.label}</a>
        ))}
      </nav>

      <section id="party" class="bg3-page-section">
        <h2 class="bg3-h2">Party</h2>
        <article class="bg3-card">
          <h3 class="bg3-card-title">{partyOverview.title}</h3>
          {partyOverview.intro && <p class="bg3-intro">{partyOverview.intro}</p>}
          <BG3Checklist items={partyOverview.items} />
        </article>
        <article class="bg3-card">
          <h3 class="bg3-card-title">{scholarStance.title}</h3>
          {scholarStance.intro && <p class="bg3-intro">{scholarStance.intro}</p>}
          <BG3Checklist items={scholarStance.items} />
        </article>
        <article class="bg3-card">
          <h3 class="bg3-card-title">{partyAlternates.title}</h3>
          {partyAlternates.intro && <p class="bg3-intro">{partyAlternates.intro}</p>}
          <BG3Checklist items={partyAlternates.items} />
        </article>
        <div class="bg3-build-grid">
          {alternateBuilds.map((build) => (
            <article class="bg3-build-card">
              <div class="bg3-build-card-header">
                <h3 class="bg3-build-card-name">{build.name}</h3>
                {build.loreFit && <span class={`lore-fit lore-fit-${build.loreFit}`}>{build.loreFit}</span>}
              </div>
              <p class="bg3-build-card-class">{build.className}</p>
              <p class="bg3-build-card-role">{build.role}</p>
              <p class="bg3-build-card-summary">{build.summary}</p>
              {build.recruit && <p class="companion-meta">{build.recruit}</p>}
            </article>
          ))}
        </div>
      </section>

      <section id="origin" class="bg3-page-section">
        <h2 class="bg3-h2">Origin + Withers</h2>
        <article class="bg3-card">
          <h3 class="bg3-card-title">{darkUrgeOrigin.title}</h3>
          {darkUrgeOrigin.intro && <p class="bg3-intro">{darkUrgeOrigin.intro}</p>}
          <BG3Checklist items={darkUrgeOrigin.items} />
        </article>
        <article class="bg3-card">
          <h3 class="bg3-card-title">{withersTiming.title}</h3>
          {withersTiming.intro && <p class="bg3-intro">{withersTiming.intro}</p>}
          <BG3Checklist items={withersTiming.items} />
        </article>
      </section>

      <section id="builds" class="bg3-page-section">
        <h2 class="bg3-h2">Single-Class Builds</h2>
        {coreBuilds.map((build) => (
          <article class="bg3-card">
            <header class="bg3-card-header">
              <h3 class="bg3-card-title">{build.name} — {build.className}</h3>
            </header>
            <p class="bg3-intro">{build.summary}</p>
            {build.setup.length > 0 && (
              <div class="bg3-build-block">
                <h4 class="bg3-h4">Setup</h4>
                {build.setup.map((section) => (
                  <div class="bg3-build-subsection">
                    <h5 class="bg3-h5">{section.title}</h5>
                    {section.intro && <p class="bg3-intro">{section.intro}</p>}
                    <BG3Checklist items={section.items} idPrefix={build.shortId} />
                  </div>
                ))}
              </div>
            )}
            {build.levels.length > 0 && (
              <div class="bg3-build-block">
                <h4 class="bg3-h4">Level Plan</h4>
                <div class="bg3-level-grid">
                  {build.levels.map((level) => (
                    <article class:list={["bg3-level-card", level.milestone && "bg3-card--milestone"]}>
                      <header class="bg3-card-header">
                        <h5 class="bg3-h5">{level.title}</h5>
                        {level.levelClass && (
                          <span class="bg3-class-chip" data-class={level.levelClass}>{level.levelClass}</span>
                        )}
                      </header>
                      {level.intro && <p class="bg3-intro">{level.intro}</p>}
                      <BG3Checklist items={level.items} idPrefix={build.shortId} />
                    </article>
                  ))}
                </div>
              </div>
            )}
          </article>
        ))}
        <article class="bg3-card">
          <h3 class="bg3-card-title">Flex slot — pick one</h3>
          <p class="bg3-intro">
            Take whichever you want to roleplay. Both keep the necrotic theme intact when geared right.
          </p>
          <div class="bg3-build-grid">
            {flexBuilds.map((build) => (
              <article class="bg3-build-card">
                <div class="bg3-build-card-header">
                  <h3 class="bg3-build-card-name">{build.name}</h3>
                  {build.loreFit && <span class={`lore-fit lore-fit-${build.loreFit}`}>{build.loreFit}</span>}
                </div>
                <p class="bg3-build-card-class">{build.className}</p>
                <p class="bg3-build-card-role">{build.role}</p>
                <p class="bg3-build-card-summary">{build.summary}</p>
                {build.recruit && <p class="companion-meta">{build.recruit}</p>}
              </article>
            ))}
          </div>
        </article>
      </section>

      <section id="lore" class="bg3-page-section">
        <h2 class="bg3-h2">Lore Decisions by Act</h2>
        <article class="bg3-card">
          <div class="bg3-act-stack">
            <div class="bg3-act-block">
              <h4 class="bg3-h4">Act 1</h4>
              <BG3Checklist items={loreByAct.act1} />
            </div>
            <div class="bg3-act-block">
              <h4 class="bg3-h4">Act 2</h4>
              <BG3Checklist items={loreByAct.act2} />
            </div>
            <div class="bg3-act-block">
              <h4 class="bg3-h4">Act 3</h4>
              <BG3Checklist items={loreByAct.act3} />
            </div>
          </div>
        </article>
      </section>

      <section id="gear" class="bg3-page-section">
        <h2 class="bg3-h2">Gear — Do Not Leave Act Without</h2>
        <article class="bg3-card">
          <div class="bg3-act-stack">
            <div class="bg3-act-block">
              <h4 class="bg3-h4">Act 1</h4>
              <BG3Checklist items={gearByAct.act1} />
            </div>
            <div class="bg3-act-block">
              <h4 class="bg3-h4">Act 2</h4>
              <BG3Checklist items={gearByAct.act2} />
            </div>
            <div class="bg3-act-block">
              <h4 class="bg3-h4">Act 3</h4>
              <BG3Checklist items={gearByAct.act3} />
            </div>
          </div>
        </article>
      </section>

      <section id="avoid" class="bg3-page-section">
        <h2 class="bg3-h2">Pitfalls</h2>
        <article class="bg3-card">
          <h3 class="bg3-card-title">{pitfalls.title}</h3>
          <BG3Checklist items={pitfalls.items} />
        </article>
      </section>

      <div class="bg3-footer-controls">
        <button id="reset-button" class="bg3-button" type="button">Reset checkboxes</button>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const storageKey = "bg3-dark-urge-guide-v2";
      const legacyKeys = [
        "bg3-dark-urge-guide-v1",
        "bg3-deathreaper-guide-v5",
        "bg3-necro-guide-v4",
        "bg3-necro-guide-v3",
        "bg3-necro-guide-v2",
        "bg3-necro-guide-v1"
      ];

      try {
        for (const k of legacyKeys) {
          try { localStorage.removeItem(k); } catch (_e) {}
        }
      } catch (_e) {}

      const loadState = () => {
        try {
          const raw = localStorage.getItem(storageKey);
          if (!raw) return { checks: {} };
          const parsed = JSON.parse(raw);
          return { checks: parsed.checks || {} };
        } catch (_e) {
          return { checks: {} };
        }
      };

      const state = loadState();
      const save = () => localStorage.setItem(storageKey, JSON.stringify(state));

      document.querySelectorAll("[data-check-id]").forEach((cb) => {
        const key = cb.dataset.checkId;
        if (!key) return;
        cb.checked = Boolean(state.checks[key]);
        cb.addEventListener("change", () => {
          state.checks[key] = cb.checked;
          save();
        });
      });

      document.getElementById("reset-button")?.addEventListener("click", () => {
        if (!window.confirm("Reset all checkboxes?")) return;
        localStorage.removeItem(storageKey);
        window.location.reload();
      });
    })();
  </script>
</BaseLayout>
