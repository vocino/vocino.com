---
interface Props {
  layout?: 'horizontal' | 'vertical';
}

const { layout = 'horizontal' } = Astro.props;

const services = [
  { name: 'Prowlarr', slug: 'prowlarr-and-flaresolverr' },
  { name: 'qBittorrent', slug: 'download-clients-qbittorrent-and-sabnzbd' },
  { name: 'SABnzbd', slug: 'download-clients-qbittorrent-and-sabnzbd' },
  { name: 'Sonarr', slug: 'the-arr-stack-sonarr-and-radarr' },
  { name: 'Radarr', slug: 'the-arr-stack-sonarr-and-radarr' },
  { name: 'Recyclarr', slug: 'quality-profiles-as-code-recyclarr' },
  { name: 'Bazarr', slug: 'subtitles-bazarr' },
  { name: 'Unpackerr', slug: 'post-download-extraction-unpackerr' },
  { name: 'Jellyseerr', slug: 'requests-jellyseerr' },
  { name: 'Jellyfin', slug: 'media-server-jellyfin' },
  { name: 'Jellystat', slug: 'shared-postgres-and-analytics-jellystat' },
  { name: 'cloudflared', slug: 'public-access-cloudflare-tunnel' },
  { name: 'Glance', slug: 'lan-dashboard-glance' },
  { name: 'Portainer', slug: 'container-management-portainer-and-wud' },
];
---

<nav class:list={['service-nav', layout === 'vertical' && 'service-nav--vertical']} aria-label="Stack services">
  <p class="service-nav__label">services[]</p>
  <ul class="service-nav__list">
    {
      services.map((svc) => (
        <li>
          <a class="service-nav__link" href={`#${svc.slug}`}>
            {svc.name}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style lang="scss">
  .service-nav {
    margin: 0;

    &__label {
      margin: 0 0 0.5rem;
      font-size: 0.625rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--term-text-muted);
    }

    &__list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      list-style: none;
      margin: 0;
      padding: 0;
    }

    &__link {
      display: inline-block;
      font-size: 0.6875rem;
      line-height: 1.3;
      padding: 0.25rem 0.45rem;
      border: 1px solid var(--term-border-dim);
      color: var(--term-text-dim);
      text-decoration: none;
      transition: border-color 0.12s, color 0.12s;

      &::before {
        content: './';
        opacity: 0.45;
      }

      &:hover {
        border-color: var(--term-phosphor);
        color: var(--term-phosphor);
      }
    }

    &--vertical {
      .service-nav__list {
        flex-direction: column;
        flex-wrap: nowrap;
        gap: 0.15rem;
      }

      .service-nav__link {
        display: block;
        padding: 0.2rem 0;
        border: 0;
        background: transparent;

        &::before {
          content: '> ';
        }

        &:hover {
          background: color-mix(in srgb, var(--term-phosphor) 6%, transparent);
        }
      }
    }
  }
</style>
