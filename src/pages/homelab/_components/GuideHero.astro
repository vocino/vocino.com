---
interface Props {
  title: string;
  description: string;
  updated?: Date;
  readingMinutes?: number;
}

const { title, description, updated, readingMinutes } = Astro.props;

const updatedLabel = updated
  ? updated.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
  : undefined;
---

<header class="guide-hero hud-corners">
  <p class="guide-hero__label label-mono">homelab</p>
  <h1 class="guide-hero__title">{title}</h1>
  <p class="guide-hero__desc">{description}</p>
  <ul class="guide-hero__meta" aria-label="Guide metadata">
    {readingMinutes && (
      <li class="guide-hero__meta-item">
        <span class="guide-hero__meta-key">read</span>
        {readingMinutes} min
      </li>
    )}
    {updatedLabel && (
      <li class="guide-hero__meta-item">
        <span class="guide-hero__meta-key">updated</span>
        {updatedLabel}
      </li>
    )}
  </ul>
</header>

<style lang="scss">
  .guide-hero {
    margin: 0;
    padding: clamp(1.5rem, 4vw, 2.25rem) clamp(1.25rem, 3vw, 2rem);
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: 6px;

    &__label {
      margin: 0 0 0.875rem;
      color: var(--section-accent, #ffb86b);
      font-size: 0.8125rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;

      &::before {
        content: "// ";
        opacity: 0.6;
      }
    }

    &__title {
      font-family: "Source Serif 4", Georgia, serif;
      font-size: clamp(1.875rem, 4vw, 2.5rem);
      font-weight: 500;
      line-height: 1.2;
      color: var(--text-primary);
      margin: 0;
      text-wrap: balance;
    }

    &__desc {
      font-size: 1.125rem;
      line-height: 1.65;
      color: var(--text-secondary);
      margin: 1rem 0 0;
      max-width: 42rem;
    }

    &__meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem 1.25rem;
      list-style: none;
      margin: 1.25rem 0 0;
      padding: 0;
      font-family: "Source Code Pro", monospace;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--text-muted);
    }

    &__meta-key {
      color: var(--section-accent, #ffb86b);
      margin-right: 0.35rem;
    }
  }
</style>
