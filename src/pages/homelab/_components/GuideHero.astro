---
interface Props {
  title: string;
  description: string;
  updated?: Date;
  readingMinutes?: number;
}

const { title, description, updated, readingMinutes } = Astro.props;

const updatedLabel = updated
  ? updated.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
  : undefined;
---

<header class="console-status terminal-pane">
  <div class="terminal-pane__titlebar">homelab — media-stack.md</div>
  <div class="terminal-pane__body console-status__body">
    <p class="console-status__line" aria-hidden="true">
      <span class="console-status__user">user</span><span class="console-status__at">@</span><span
        class="console-status__host">homelab</span><span class="console-status__colon">:</span><span
        class="console-status__path">~/media-stack</span><span class="console-status__prompt">$</span>
      <span class="console-status__cmd">cat README</span>
    </p>
    <h1 class="console-status__title">{title}</h1>
    <p class="console-status__desc">{description}</p>
    <dl class="console-status__meta" aria-label="Guide metadata">
      {
        readingMinutes && (
          <div class="console-status__meta-row">
            <dt>read</dt>
            <dd>{readingMinutes} min</dd>
          </div>
        )
      }
      {
        updatedLabel && (
          <div class="console-status__meta-row">
            <dt>mtime</dt>
            <dd>{updatedLabel}</dd>
          </div>
        )
      }
      <div class="console-status__meta-row">
        <dt>mode</dt>
        <dd>honest-docs</dd>
      </div>
    </dl>
  </div>
</header>

<style lang="scss">
  .console-status {
    margin: 0;

    &__body {
      padding: 0.85rem 1rem 1rem;
    }

    &__line {
      margin: 0 0 0.65rem;
      font-size: 0.75rem;
      line-height: 1.4;
      color: var(--term-text-dim);
      word-break: break-word;
    }

    &__user {
      color: var(--term-phosphor);
      font-weight: 600;
    }

    &__at,
    &__colon {
      color: var(--term-text-muted);
    }

    &__host {
      color: var(--term-text);
    }

    &__path {
      color: var(--term-text-dim);
    }

    &__prompt {
      color: var(--term-phosphor);
      margin: 0 0.35rem 0 0.15rem;
    }

    &__cmd {
      color: var(--term-text);
    }

    &__title {
      font-family: 'Source Code Pro', monospace;
      font-size: clamp(1.125rem, 3vw, 1.5rem);
      font-weight: 700;
      line-height: 1.25;
      letter-spacing: 0.02em;
      color: var(--term-text);
      margin: 0;
      text-wrap: balance;
    }

    &__desc {
      font-size: 0.8125rem;
      line-height: 1.6;
      color: var(--term-text-dim);
      margin: 0.65rem 0 0;
      max-width: 52rem;
    }

    &__meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem 1.25rem;
      margin: 0.85rem 0 0;
      padding: 0;
    }

    &__meta-row {
      display: flex;
      align-items: baseline;
      gap: 0.4rem;
      margin: 0;
      font-size: 0.6875rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;

      dt {
        margin: 0;
        color: var(--term-text-muted);
        font-weight: 400;

        &::after {
          content: '=';
          margin-left: 0.15rem;
          color: var(--term-phosphor);
          opacity: 0.6;
        }
      }

      dd {
        margin: 0;
        color: var(--term-phosphor);
        font-weight: 600;
      }
    }
  }
</style>
