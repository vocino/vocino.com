---
import GuideToc from './GuideToc.astro';
import { getTocHeadings } from '../_lib/guide-toc';
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const sectionCount = getTocHeadings(headings).length;
---

{
  sectionCount > 0 && (
    <details class="guide-toc-drawer">
      <summary class="guide-toc-drawer__summary">
        <span class="guide-toc-drawer__title">./jump --sections</span>
        <span class="guide-toc-drawer__count">{sectionCount}</span>
      </summary>
      <div class="guide-toc-drawer__panel">
        <GuideToc headings={headings} />
      </div>
    </details>
  )
}
