---
import '../_styles/guide-tokens.scss';
import '../_styles/guide-layout.scss';
import '../_styles/guide-toc.scss';
import '../_styles/guide-prose.scss';
import GuideHero from './GuideHero.astro';
import GuideDisclaimer from './GuideDisclaimer.astro';
import GuideVarsPanel from './GuideVarsPanel.astro';
import ServiceNav from './ServiceNav.astro';
import StackDiagram from './StackDiagram.astro';
import GuideToc from './GuideToc.astro';
import GuideTocDrawer from './GuideTocDrawer.astro';
import type { MarkdownHeading } from 'astro';

interface Props {
  title: string;
  description: string;
  updated?: Date;
  readingMinutes?: number;
  headings: MarkdownHeading[];
}

const { title, description, updated, readingMinutes, headings } = Astro.props;
---

<div class="homelab-guide">
  <aside class="homelab-guide__sidebar" aria-hidden="true"></aside>

  <nav class="homelab-guide__toc-fixed" aria-label="Table of contents">
    <GuideToc headings={headings} />
  </nav>

  <main class="homelab-guide__main">
    <GuideTocDrawer headings={headings} />

    <noscript>
      <p class="guide-noscript">
        JavaScript is required to personalize hostnames and copy customized snippets. The guide still
        works with default placeholders.
      </p>
    </noscript>

    <div class="homelab-guide__chrome">
      <GuideHero
        title={title}
        description={description}
        updated={updated}
        readingMinutes={readingMinutes}
      />
      <GuideDisclaimer />
      <GuideVarsPanel />
      <ServiceNav />
      <StackDiagram />
    </div>

    <article class="guide-prose">
      <slot />
    </article>
  </main>
</div>

<script>
  import '../_lib/guide-vars.client.ts';
</script>

