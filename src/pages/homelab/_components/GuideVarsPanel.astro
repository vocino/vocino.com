---
import '../_styles/guide-vars.scss';
import GuideVarsForm from './GuideVarsForm.astro';

interface Props {
  variant?: 'embedded' | 'pane';
}

const { variant = 'embedded' } = Astro.props;
const isPane = variant === 'pane';
---

{
  isPane ? (
    <div class="guide-vars guide-vars--pane">
      <div class="guide-vars__body">
        <GuideVarsForm />
      </div>
    </div>
  ) : (
    <details class="guide-vars" open>
      <summary class="guide-vars__summary">
        session.env
        <span class="guide-vars__hint">live substitution</span>
      </summary>
      <div class="guide-vars__body">
        <GuideVarsForm />
      </div>
    </details>
  )
}
