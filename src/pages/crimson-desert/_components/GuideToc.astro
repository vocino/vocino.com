---
import { getTocAnchor, getTocHeadings } from '../_lib/guide-toc';
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
  idPrefix: string;
}

const { headings, idPrefix } = Astro.props;
const tocHeadings = getTocHeadings(headings);
---

{
  tocHeadings.length > 0 && (
    <nav class="guide-toc">
      <p class="guide-toc__label">Contents</p>
      <ol class="guide-toc__list">
        {tocHeadings.map((heading) => {
          const anchor = getTocAnchor(idPrefix, heading.slug);
          return (
            <li>
              <a href={`#${anchor}`} data-toc-slug={anchor} class="guide-toc__link">
                {heading.text}
              </a>
            </li>
          );
        })}
      </ol>
    </nav>
  )
}
