---
import '../_styles/hub-tokens.scss';
import '../_styles/hub-layout.scss';
import '../_styles/hub-tabs.scss';
import '../_styles/hub-components.scss';
import '../_styles/guide-toc.scss';
import '../_styles/guide-prose.scss';
import '../_styles/guide-tables.scss';
import '../_styles/skill-ladder.scss';
import CdHero from './CdHero.astro';
import CharacterTabs, { type CharacterGuideMeta } from './CharacterTabs.astro';
import { getCrimsonDesertHeroBackgroundUrls } from '../_lib/cd-game-art';
import type { MarkdownHeading } from 'astro';

const heroBackground = getCrimsonDesertHeroBackgroundUrls();

interface Props {
  hubTitle: string;
  hubDescription: string;
  kliffHeadings: MarkdownHeading[];
  damianeHeadings: MarkdownHeading[];
  kliffMeta: CharacterGuideMeta;
  damianeMeta: CharacterGuideMeta;
  kliffUpdated?: Date;
  kliffReadingMinutes?: number;
  boxArtUrl: string;
}

const {
  hubTitle,
  hubDescription,
  kliffHeadings,
  damianeHeadings,
  kliffMeta,
  damianeMeta,
  kliffUpdated,
  kliffReadingMinutes,
  boxArtUrl,
} = Astro.props;
---

<div class="cd-hub">
  <div class="cd-hub__grain" aria-hidden="true"></div>
  <div class="cd-hub__ambient" aria-hidden="true">
    <picture class="cd-hub__ambient-picture">
      <source
        srcset={heroBackground.animated}
        type="image/webp"
        media="(prefers-reduced-motion: no-preference)"
      />
      <img
        class="cd-hub__ambient-img"
        src={heroBackground.static}
        alt=""
        width={1920}
        height={620}
        decoding="async"
        loading="lazy"
      />
    </picture>
    <div class="cd-hub__ambient-scrim"></div>
  </div>
  <div class="cd-hub__inner">
    <CdHero
      label="Crimson Desert"
      title={hubTitle}
      description={hubDescription}
      updated={kliffUpdated}
      readingMinutes={kliffReadingMinutes}
      boxArtUrl={boxArtUrl}
    />

    <CharacterTabs
      kliffHeadings={kliffHeadings}
      damianeHeadings={damianeHeadings}
      kliffMeta={kliffMeta}
      damianeMeta={damianeMeta}
    >
      <slot name="kliff" slot="kliff" />
      <slot name="damiane" slot="damiane" />
    </CharacterTabs>
  </div>
</div>

<script>
  import '../_lib/guide-progress.client.ts';
</script>
