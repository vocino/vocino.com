---
import { getTocHeadings } from '../_lib/guide-toc';
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
  panelId: string;
}

const { headings, panelId } = Astro.props;
const tocHeadings = getTocHeadings(headings);
---

{
  tocHeadings.length > 0 && (
    <details class="guide-toc-drawer" id={`cd-toc-panel-${panelId}`}>
      <summary>Contents</summary>
      <nav class="guide-toc" aria-label="Table of contents">
        <ol class="guide-toc__list">
          {tocHeadings.map((heading) => (
            <li>
              <a href={`#${heading.slug}`} data-toc-slug={heading.slug} class="guide-toc__link">
                {heading.text}
              </a>
            </li>
          ))}
        </ol>
      </nav>
    </details>
  )
}
