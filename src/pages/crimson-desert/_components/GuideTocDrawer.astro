---
import { getTocAnchor, getTocHeadings } from '../_lib/guide-toc';
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
  panelId: string;
  idPrefix: string;
}

const { headings, panelId, idPrefix } = Astro.props;
const tocHeadings = getTocHeadings(headings);
---

{
  tocHeadings.length > 0 && (
    <details class="guide-toc-drawer" id={`cd-toc-panel-${panelId}`}>
      <summary>Contents</summary>
      <nav class="guide-toc" aria-label="Table of contents">
        <ol class="guide-toc__list">
          {tocHeadings.map((heading) => {
            const anchor = getTocAnchor(idPrefix, heading.slug);
            return (
              <li>
                <a href={`#${anchor}`} data-toc-slug={anchor} class="guide-toc__link">
                  {heading.text}
                </a>
              </li>
            );
          })}
        </ol>
      </nav>
    </details>
  )
}
