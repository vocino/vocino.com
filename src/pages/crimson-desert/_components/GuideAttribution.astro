---
import { cdWikiAttribution } from '../_lib/cd-icons';
import { getCrimsonDesertHeroBackgroundAttribution } from '../_lib/cd-game-art';

const heroBackgroundAttribution = getCrimsonDesertHeroBackgroundAttribution();
---

<footer class="cd-guide-attribution">
  <p>{cdWikiAttribution}</p>
  <p>
    <a href="https://crimsondesert.fandom.com/wiki/Crimson_Desert_Wiki" rel="noopener noreferrer" target="_blank"
      >Crimson Desert Wiki</a
    >
    is the reference for skill and equipment icons. Game content belongs to Pearl Abyss.
  </p>
  {
    heroBackgroundAttribution && (
      <p>
        Hero background via{' '}
        <a href={heroBackgroundAttribution.url} rel="noopener noreferrer" target="_blank">
          SteamGridDB
        </a>{' '}
        by {heroBackgroundAttribution.author}.
      </p>
    )
  }
</footer>
