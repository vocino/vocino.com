---
export const prerender = true;

import HubLayout from '../../layouts/HubLayout.astro';
import CdHubShell from './_components/CdHubShell.astro';
import { getHubBreadcrumb, getHubBySlug } from '../../data/hubs';
import { toAbsoluteUrl } from '../../lib/seo';
import { cdCharacters } from './_lib/cd-characters';
import { getCrimsonDesertBoxArtUrl } from './_lib/cd-game-art';
import { getEntry, render } from 'astro:content';

const hub = getHubBySlug('crimson-desert');
const boxArtUrl = getCrimsonDesertBoxArtUrl();

const kliffEntry = await getEntry('crimson-desert', 'kliff');
if (!kliffEntry) {
  throw new Error('Crimson Desert guide entry "kliff" not found');
}

const damianeEntry = await getEntry('crimson-desert', 'damiane');
if (!damianeEntry) {
  throw new Error('Crimson Desert guide entry "damiane" not found');
}

const { Content: KliffContent, headings: kliffHeadings } = await render(kliffEntry);
const { Content: DamianeContent, headings: damianeHeadings } = await render(damianeEntry);

const { updated: kliffUpdated } = kliffEntry.data;
const { updated: damianeUpdated } = damianeEntry.data;

const pageTitle = 'Crimson Desert builds';
const intro =
  'Build notes for Kliff, Damiane, and Oongka. Kliff\'s Hernand starter and Damiane\'s pistol/musket gunslinger are written; Oongka is still half-baked.';

const combinedBody = [kliffEntry.body, damianeEntry.body].filter(Boolean).join('\n');
const wordCount = combinedBody.split(/\s+/).filter(Boolean).length;
const readingMinutes = Math.max(1, Math.round(wordCount / 220));

const modifiedTime = [kliffUpdated, damianeUpdated]
  .filter((d): d is Date => d instanceof Date)
  .sort((a, b) => b.getTime() - a.getTime())[0]
  ?.toISOString();

const characterListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: "Travis Vocino's Crimson Desert builds",
  url: toAbsoluteUrl(`/${hub.slug}`),
  numberOfItems: cdCharacters.length,
  itemListElement: cdCharacters.map((character, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: character.status === 'live' ? `${character.label} build` : `${character.label} (coming soon)`,
    url: toAbsoluteUrl(`/${hub.slug}#${character.id}`),
  })),
};
---

<HubLayout
  pageType="hub"
  title={pageTitle}
  hubName={hub.name}
  description={hub.description}
  canonicalPath={`/${hub.slug}`}
  breadcrumb={getHubBreadcrumb(hub)}
  imagePath={hub.imagePath}
  imageAlt={hub.ogImageAlt}
  accent={hub.accent}
  noindex={!hub.indexable}
  schema={characterListSchema}
  modifiedTime={modifiedTime}
>
  <CdHubShell
    hubTitle={pageTitle}
    hubDescription={intro}
    kliffHeadings={kliffHeadings}
    damianeHeadings={damianeHeadings}
    kliffUpdated={kliffUpdated}
    kliffReadingMinutes={readingMinutes}
    boxArtUrl={boxArtUrl}
  >
    <KliffContent slot="kliff" />
    <DamianeContent slot="damiane" />
  </CdHubShell>
</HubLayout>
