---
import { BG3_GUIDE_ACTS, getActGroups, getSectionActs, getSectionLabels } from '../_lib/guide-acts';

const sectionLabels = getSectionLabels();
const sectionActs = getSectionActs();
const actGroups = getActGroups();
---

<div
  class="bg3-play-bar"
  role="navigation"
  aria-label="Guide navigation"
  data-bg3-play-bar
  data-section-labels={JSON.stringify(sectionLabels)}
  data-section-acts={JSON.stringify(sectionActs)}
  data-act-slugs={JSON.stringify(BG3_GUIDE_ACTS.map((a) => a.slug))}
>
  <div class="bg3-resume" data-resume-banner hidden>
    <button type="button" class="bg3-resume__btn" data-resume-btn>
      Continue from <strong data-resume-label>…</strong>
      <span aria-hidden="true">→</span>
    </button>
  </div>

  <div class="bg3-play-bar__row">
    <div class="bg3-play-bar__now">
      <span class="bg3-play-bar__kicker" data-current-act>Playing now</span>
      <span class="bg3-play-bar__section" data-current-section>Start</span>
      <span class="bg3-play-bar__next-hint" data-next-hint hidden></span>
    </div>
    <span class="bg3-play-bar__progress" data-checkpoint-progress aria-live="polite">0 / 10</span>
    <div class="bg3-play-bar__jump">
      <label class="visually-hidden" for="bg3-act-jump">Jump to step</label>
      <select id="bg3-act-jump" class="bg3-play-bar__select">
        <option value="">Jump to step…</option>
        {actGroups.map((group) => (
          <optgroup label={group.act}>
            {group.beats.map((beat) => (
              <option value={beat.slug}>{beat.label}</option>
            ))}
          </optgroup>
        ))}
      </select>
      <a class="bg3-play-bar__next-btn" data-play-next href="#" hidden aria-label="Go to next step">
        Next →
      </a>
      <button
        type="button"
        class="bg3-play-bar__sections-btn"
        data-toc-toggle
        aria-expanded="false"
        aria-controls="bg3-toc-panel"
      >
        List
      </button>
    </div>
  </div>

  <div class="bg3-play-bar__track" aria-hidden="true">
    <span class="bg3-play-bar__fill" data-progress-fill></span>
  </div>
</div>

<style lang="scss">
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }
</style>
