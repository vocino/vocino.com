---
interface Props {
  title: string;
  description: string;
  updated?: Date;
  readingMinutes?: number;
  label?: string;
}

const { title, description, updated, readingMinutes, label = 'Second screen' } = Astro.props;

const updatedLabel = updated
  ? updated.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
  : undefined;
---

<header class="guide-hero">
  <p class="guide-hero__label label-mono">{label}</p>
  <h1 class="guide-hero__title">{title}</h1>
  <p class="guide-hero__desc">{description}</p>
  <ul class="guide-hero__meta" aria-label="Guide metadata">
    {
      readingMinutes && (
        <li class="guide-hero__meta-item guide-hero__meta-item--read">
          <span class="guide-hero__meta-key">read</span>
          {readingMinutes} min
        </li>
      )
    }
    {
      updatedLabel && (
        <li class="guide-hero__meta-item">
          <span class="guide-hero__meta-key">updated</span>
          {updatedLabel}
        </li>
      )
    }
  </ul>
</header>

<style lang="scss">
  .guide-hero {
    margin: 0;
    padding: 0.875rem 1rem;
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: 8px;

    @media (min-width: 640px) {
      padding: clamp(1.125rem, 3vw, 1.5rem) clamp(1rem, 3vw, 1.5rem);
      border-radius: 6px;
    }

    &__label {
      margin: 0 0 0.5rem;
      color: var(--section-accent, #46e08b);
      font-size: 0.6875rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;

      &::before {
        content: '// ';
        opacity: 0.6;
      }
    }

    &__title {
      font-family: 'Source Serif 4', Georgia, serif;
      font-size: clamp(1.25rem, 3.5vw, 1.875rem);
      font-weight: 500;
      line-height: 1.2;
      margin: 0;
      color: var(--text-primary);
    }

    &__desc {
      font-size: 0.9375rem;
      line-height: 1.5;
      color: var(--text-secondary);
      margin: 0.5rem 0 0;
      max-width: 42rem;

      @media (min-width: 640px) {
        font-size: 1.0625rem;
        line-height: 1.6;
        margin-top: 0.75rem;
      }
    }

    &__meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem 1rem;
      list-style: none;
      margin: 0.65rem 0 0;
      padding: 0;
      font-family: 'Source Code Pro', monospace;
      font-size: 0.6875rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-muted);
    }

    &__meta-item--read {
      @media (max-width: 479px) {
        display: none;
      }
    }

    &__meta-key {
      color: var(--section-accent, #46e08b);
      margin-right: 0.35rem;
    }
  }
</style>
