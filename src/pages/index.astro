---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import SiteBrand from '../components/SiteBrand.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { getHomepageHubs } from '../lib/homepage-hubs';

const homepageHubs = await getHomepageHubs();

const homeTitle = 'Travis Vocino (Vocino) — Perfect blend of technology and magic';
const homeDescription =
  'Travis Vocino — maker, nerd tchotchke collector. Personal site with Baldur\'s Gate 3 Honour Mode and self-hosted homelab guides.';
---

<BaseLayout
  title={homeTitle}
  description={homeDescription}
  pageType="home"
  canonicalPath="/"
>
  <div class="centered-content">
    <div class="content-wrapper">
      <SiteBrand />

      <h1 class="tagline">Perfect blend of <span class="word-tech">technology</span>&nbsp;and&nbsp;<span class="word-magic">magic</span>.</h1>

      <p class="bio">From the desk of Travis&nbsp;Vocino. Maker. Nerd tchotchke&nbsp;collector. Chaotic&nbsp;good.</p>

      <SocialLinks />

      {
        homepageHubs.length > 0 && (
          <section class="home-hub-intro" aria-label="Guides and projects">
            <h2 class="home-hub-intro__heading">Guides</h2>
            <ul class="home-hub-intro__list">
              {homepageHubs.map((hub) => (
                <li class="home-hub-intro__item">
                  <a
                    class="home-hub-intro__link"
                    href={hub.href}
                    style={`--hub-accent: ${hub.accent}`}
                  >
                    {hub.label}
                  </a>
                  <span class="home-hub-intro__desc"> — {hub.description}</span>
                </li>
              ))}
            </ul>
          </section>
        )
      }
    </div>
  </div>

  {
    homepageHubs.length > 0 && (
      <nav class="home-hub-pills" aria-label="Hub links">
        <ul class="home-hub-pills__list">
          {homepageHubs.map((hub) => (
            <li class="home-hub-pills__item">
              <a
                class="home-hub-pills__link"
                href={hub.href}
                style={`--hub-accent: ${hub.accent}`}
              >
                {hub.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    )
  }
</BaseLayout>
