---
import BaseLayout from "../layouts/BaseLayout.astro";
import SpecGrid from "../components/spec/SpecGrid.astro";
import IdentityPlate from "../components/spec/IdentityPlate.astro";
import Tagline from "../components/spec/Tagline.astro";
import LogoDimensionDiagram from "../components/spec/LogoDimensionDiagram.astro";
import IOFlowDiagram from "../components/spec/IOFlowDiagram.astro";
import BroadcastStatus from "../components/spec/BroadcastStatus.astro";
import ChannelsManifest from "../components/spec/ChannelsManifest.astro";
import Capabilities from "../components/spec/Capabilities.astro";
import BarcodeSerial from "../components/spec/BarcodeSerial.astro";
import QRStamp from "../components/spec/QRStamp.astro";
import CertificationStamp from "../components/spec/CertificationStamp.astro";
import HandlingIcons from "../components/spec/HandlingIcons.astro";
import FieldSightings from "../components/spec/FieldSightings.astro";
---

<BaseLayout
  page="spec"
  title="Vocino — Perfect blend of technology and magic"
  description="Travis Vocino · I build stuff at Meta. Nerd tchotchke collector. Chaotic good. Perfect blend of technology and magic."
>
  <SpecGrid>
    <IdentityPlate />
    <Tagline />
    <LogoDimensionDiagram />
    <IOFlowDiagram />
    <BroadcastStatus />
    <ChannelsManifest />
    <Capabilities />
    <BarcodeSerial />
    <QRStamp />
    <HandlingIcons />
    <FieldSightings />
    <CertificationStamp />
  </SpecGrid>
</BaseLayout>
