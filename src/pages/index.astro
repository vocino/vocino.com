---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteBrand from '../components/SiteBrand.astro';
import SocialLinks from '../components/SocialLinks.astro';
---

<BaseLayout
  title="Vocino - Perfect blend of technology and magic"
  description="Personal website of Travis Vocino - Maker, nerd tchotchke collector, and creative technologist. Perfect blend of technology and magic."
>

  <div class="centered-content">

    <!-- Top-left corner annotation -->
    <svg class="corner-annotation corner-tl"
         xmlns="http://www.w3.org/2000/svg"
         width="120" height="120" viewBox="0 0 120 120"
         aria-hidden="true">
      <polyline points="8,42 8,8 42,8"
                fill="none" stroke="rgba(0,204,255,0.28)" stroke-width="1"/>
      <line x1="8" y1="25" x2="18" y2="25"
            fill="none" stroke="rgba(0,204,255,0.18)" stroke-width="0.75"/>
      <text x="13" y="57"
            font-family="monospace" font-size="7" fill="rgba(0,204,255,0.22)"
            letter-spacing="1">COORD</text>
      <text x="13" y="68"
            font-family="monospace" font-size="6" fill="rgba(0,204,255,0.16)"
            letter-spacing="0.5">40.7128&#176;N</text>
      <text x="13" y="77"
            font-family="monospace" font-size="6" fill="rgba(0,204,255,0.16)"
            letter-spacing="0.5">74.0060&#176;W</text>
      <text x="13" y="92"
            font-family="monospace" font-size="6" fill="rgba(0,204,255,0.13)"
            letter-spacing="0.5">REF:001</text>
      <circle cx="10" cy="101" r="2" fill="rgba(61,250,154,0.35)"/>
      <line x1="14" y1="101" x2="32" y2="101"
            stroke="rgba(61,250,154,0.18)" stroke-width="0.5"/>
    </svg>

    <!-- Top-right corner annotation -->
    <svg class="corner-annotation corner-tr"
         xmlns="http://www.w3.org/2000/svg"
         width="120" height="120" viewBox="0 0 120 120"
         aria-hidden="true">
      <polyline points="112,42 112,8 78,8"
                fill="none" stroke="rgba(0,204,255,0.28)" stroke-width="1"/>
      <line x1="112" y1="25" x2="102" y2="25"
            fill="none" stroke="rgba(0,204,255,0.18)" stroke-width="0.75"/>
      <text x="107" y="57" text-anchor="end"
            font-family="monospace" font-size="7" fill="rgba(0,204,255,0.22)"
            letter-spacing="1">V2.0</text>
      <text x="107" y="68" text-anchor="end"
            font-family="monospace" font-size="6" fill="rgba(0,204,255,0.16)"
            letter-spacing="0.5">BUILD 0312</text>
      <text x="107" y="77" text-anchor="end"
            font-family="monospace" font-size="6" fill="rgba(0,204,255,0.16)"
            letter-spacing="0.5">STD-MKII</text>
      <text x="107" y="92" text-anchor="end"
            font-family="monospace" font-size="6" fill="rgba(230,232,122,0.22)"
            letter-spacing="0.5">&#9651; NOMINAL</text>
    </svg>

    <!-- Bottom-left corner annotation -->
    <svg class="corner-annotation corner-bl"
         xmlns="http://www.w3.org/2000/svg"
         width="120" height="120" viewBox="0 0 120 120"
         aria-hidden="true">
      <polyline points="8,78 8,112 42,112"
                fill="none" stroke="rgba(0,204,255,0.28)" stroke-width="1"/>
      <line x1="8" y1="95" x2="18" y2="95"
            fill="none" stroke="rgba(0,204,255,0.18)" stroke-width="0.75"/>
      <!-- Measurement annotation bracket -->
      <line x1="22" y1="52" x2="22" y2="108"
            stroke="rgba(0,204,255,0.12)" stroke-width="0.5"/>
      <line x1="17" y1="52" x2="27" y2="52"
            stroke="rgba(0,204,255,0.12)" stroke-width="0.5"/>
      <line x1="17" y1="108" x2="27" y2="108"
            stroke="rgba(0,204,255,0.12)" stroke-width="0.5"/>
      <text x="30" y="84"
            font-family="monospace" font-size="6" fill="rgba(0,204,255,0.14)"
            letter-spacing="0.5">48U</text>
      <text x="13" y="108"
            font-family="monospace" font-size="6" fill="rgba(0,204,255,0.2)"
            letter-spacing="0.5">VOCINO.COM</text>
    </svg>

    <!-- Bottom-right corner annotation -->
    <svg class="corner-annotation corner-br"
         xmlns="http://www.w3.org/2000/svg"
         width="120" height="120" viewBox="0 0 120 120"
         aria-hidden="true">
      <polyline points="112,78 112,112 78,112"
                fill="none" stroke="rgba(0,204,255,0.28)" stroke-width="1"/>
      <line x1="112" y1="95" x2="102" y2="95"
            fill="none" stroke="rgba(0,204,255,0.18)" stroke-width="0.75"/>
      <!-- Circuit trace path with nodes -->
      <polyline points="58,58 80,58 80,80 102,80"
                fill="none" stroke="rgba(0,204,255,0.1)" stroke-width="0.75"/>
      <circle cx="80" cy="58" r="1.5" fill="rgba(0,204,255,0.2)"/>
      <circle cx="80" cy="80" r="1.5" fill="rgba(0,204,255,0.2)"/>
      <text x="107" y="48" text-anchor="end"
            font-family="monospace" font-size="6" fill="rgba(0,204,255,0.16)"
            letter-spacing="0.5">SYS.OK</text>
      <text x="107" y="38" text-anchor="end"
            font-family="monospace" font-size="6" fill="rgba(61,250,154,0.28)"
            letter-spacing="0.5">&#9632; ACTIVE</text>
    </svg>

    <div class="content-wrapper">
      <SiteBrand />

      <h1 class="tagline">Perfect blend of <span class="word-tech">technology</span>&nbsp;and&nbsp;<span class="word-magic">magic</span>.</h1>

      <p class="bio">From the desk of Travis&nbsp;Vocino. Maker. Nerd tchotchke&nbsp;collector. Chaotic&nbsp;good.</p>

      <SocialLinks />

      <!-- Micro-annotation labels positioned outside the content wrapper edges -->
      <span class="micro-label micro-label--tl" aria-hidden="true">SYS_ID: VCN-001</span>
      <span class="micro-label micro-label--tr" aria-hidden="true">CLASS: PERSONAL</span>
      <span class="micro-label micro-label--bl" aria-hidden="true">LAT 40.71&#176; LON -74.00&#176;</span>
      <span class="micro-label micro-label--br" aria-hidden="true">&#9632; ONLINE</span>
    </div>
  </div>
</BaseLayout>

<style>
  /* Corner annotation SVGs */
  .corner-annotation {
    position: absolute;
    pointer-events: none;
    opacity: 0;
    animation: fadeInCorner 1.2s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  @keyframes fadeInCorner {
    from { opacity: 0; }
    to   { opacity: 0.75; }
  }

  .corner-tl { top: 24px;    left: 24px;    animation-delay: 0.7s; }
  .corner-tr { top: 24px;    right: 24px;   animation-delay: 0.8s; }
  .corner-bl { bottom: 24px; left: 24px;    animation-delay: 0.9s; }
  .corner-br { bottom: 24px; right: 24px;   animation-delay: 1.0s; }

  @media (max-width: 768px) {
    .corner-annotation { display: none; }
  }

  /* Micro-label text annotations outside content wrapper */
  .micro-label {
    position: absolute;
    font-family: 'Source Code Pro', monospace;
    font-size: 9px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(0, 204, 255, 0.28);
    pointer-events: none;
    white-space: nowrap;
    opacity: 0;
    animation: fadeInUp 1s cubic-bezier(0.4, 0, 0.2, 1) backwards;
  }

  .micro-label--tl { top: -22px;    left: 0;   animation-delay: 0.95s; }
  .micro-label--tr { top: -22px;    right: 0;  animation-delay: 1.0s;  }
  .micro-label--bl { bottom: -22px; left: 0;   animation-delay: 1.05s; }
  .micro-label--br { bottom: -22px; right: 0;  animation-delay: 1.1s;  }

  @media (max-width: 768px) {
    .micro-label { display: none; }
  }
</style>
